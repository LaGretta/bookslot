<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookSlot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">
                <i class="bi bi-calendar-check-fill me-1"></i>BookSlot
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link px-3" href="/#features">Можливості</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3" href="/#pricing">Ціни</a>
                    </li>
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="py-5 mt-4">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="footer-brand mb-2">
                        <i class="bi bi-calendar-check-fill me-1"></i>BookSlot
                    </div>
                    <p style="font-size:.9rem">Онлайн-запис для малого бізнесу.<br>Просто, зручно, доступно.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white fw-600 mb-3">Продукт</h6>
                    <ul class="list-unstyled" style="font-size:.9rem">
                        <li class="mb-2"><a href="/#features">Можливості</a></li>
                        <li class="mb-2"><a href="/#pricing">Ціни</a></li>
                        <li class="mb-2"><a asp-page="/Account/Register" asp-area="Identity">Реєстрація</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white fw-600 mb-3">Контакти</h6>
                    <ul class="list-unstyled" style="font-size:.9rem">
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i>support@bookslot.com</li>
                        <li class="mb-2"><i class="bi bi-telegram me-2"></i>@@bookslot_ua</li>
                    </ul>
                </div>
            </div>
            <hr style="border-color:#1e293b;margin:2rem 0 1rem">
            <p class="text-center mb-0" style="font-size:.82rem">&copy; 2026 BookSlot. Всі права захищені.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
