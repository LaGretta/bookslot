<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookSlot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">
                <i class="bi bi-calendar-check"></i> BookSlot
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">Головна</a>
                    </li>
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="py-5 mt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5 class="text-white fw-bold"><i class="bi bi-calendar-check"></i> BookSlot</h5>
                    <p>Онлайн-запис для малого бізнесу. Просто, зручно, доступно.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="text-white">Продукт</h6>
                    <ul class="list-unstyled">
                        <li><a href="#features">Можливості</a></li>
                        <li><a href="#pricing">Ціни</a></li>
                        <li><a asp-page="/Account/Register" asp-area="Identity">Реєстрація</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4">
                    <h6 class="text-white">Контакти</h6>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-envelope me-2"></i>support@bookslot.com</li>
                        <li><i class="bi bi-telegram me-2"></i>@@bookslot_ua</li>
                    </ul>
                </div>
            </div>
            <hr style="border-color:#333">
            <p class="text-center mb-0" style="font-size:.85rem">&copy; 2026 BookSlot. Всі права захищені.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
