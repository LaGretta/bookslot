@using Microsoft.AspNetCore.Identity
@using BookSlot.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var isLandingReact = ViewData["LandingReact"] as bool? == true;
    var isSignedIn = SignInManager.IsSignedIn(User);
    var currentUser = isSignedIn ? await UserManager.GetUserAsync(User) : null;
    var accountName = currentUser?.FullName;
    var accountEmail = currentUser?.Email ?? User.Identity?.Name ?? "";
    var profileName = !string.IsNullOrWhiteSpace(accountName)
        ? accountName
        : (!string.IsNullOrWhiteSpace(accountEmail) ? accountEmail : "BookSlot");
    var profileInitial = !string.IsNullOrWhiteSpace(profileName)
        ? profileName.Trim()[0].ToString().ToUpperInvariant()
        : "B";
    var isDashboardReactShell = !isLandingReact
        && isSignedIn
        && Context.Request.Path.StartsWithSegments("/Dashboard");
    var bodyClass = isLandingReact
        ? "landing-react-body"
        : (isDashboardReactShell ? "bs-product-react-active" : "");
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookSlot</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <script>
        document.documentElement.dataset.theme = 'dark';
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @if (isDashboardReactShell)
    {
        <link rel="stylesheet" href="~/dist/assets/bookslot-product.css" asp-append-version="true" />
    }
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@bodyClass">
    @if (!isLandingReact)
    {
    <nav class="navbar navbar-expand-lg sticky-top bs-navbar" id="main-nav">
        <div class="container">
            <a class="navbar-brand" href="/">
                <span class="brand-icon" aria-hidden="true"><span class="bs-brand-spark"></span></span>
                <span class="brand-text">BookSlot</span>
            </a>

            @if (!isSignedIn)
            {
                <div class="bs-nav-links d-none d-lg-flex">
                    <a class="nav-link px-3" href="/#ai-flow">AI-помічник</a>
                    <a class="nav-link px-3" href="/#ai-flow">Можливості</a>
                    <a class="nav-link px-3" href="/#pricing">Тарифи</a>
                </div>
            }

            <div class="bs-nav-actions ms-auto">
                <div class="bs-language-switch" data-language-switch aria-label="Перемикач мови">
                    <button type="button" data-lang="uk">UA</button>
                    <button type="button" data-lang="en">EN</button>
                </div>
                <button class="bs-menu-trigger" type="button" data-bs-toggle="offcanvas" data-bs-target="#accountMenu" aria-controls="accountMenu" aria-label="Відкрити меню профілю">
                    @if (isSignedIn)
                    {
                        <span class="bs-avatar">@profileInitial</span>
                        <span class="bs-menu-text d-none d-sm-inline">Профіль</span>
                    }
                    else
                    {
                        <span class="bs-menu-text">Меню</span>
                    }
                    <i class="bi bi-list"></i>
                </button>
            </div>
        </div>
    </nav>

    <div class="offcanvas offcanvas-end bs-account-drawer" tabindex="-1" id="accountMenu" aria-labelledby="accountMenuLabel">
        <div class="offcanvas-header">
            <a class="navbar-brand" href="/">
                <span class="brand-icon" aria-hidden="true"><span class="bs-brand-spark"></span></span>
                <span class="brand-text">BookSlot</span>
            </a>
            <button type="button" class="bs-close-button" data-bs-dismiss="offcanvas" aria-label="Закрити меню">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="offcanvas-body">
            @if (isSignedIn)
            {
                <div class="bs-profile-card">
                    <span class="bs-profile-avatar">@profileInitial</span>
                    <div class="min-w-0">
                        <div class="bs-profile-name">@profileName</div>
                        <div class="bs-profile-email">@accountEmail</div>
                    </div>
                </div>

                <div class="bs-drawer-section">
                    <div class="bs-drawer-label">Акаунт</div>
                    <a class="bs-drawer-link" asp-page="/Dashboard/Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>Дашборд</span>
                    </a>
                    <a class="bs-drawer-link" asp-page="/Dashboard/Bookings/Index">
                        <i class="bi bi-calendar-check"></i>
                        <span>Записи</span>
                    </a>
                    <a class="bs-drawer-link" asp-page="/Dashboard/Services/Index">
                        <i class="bi bi-scissors"></i>
                        <span>Послуги</span>
                    </a>
                    <a class="bs-drawer-link" asp-page="/Dashboard/Schedule/Index">
                        <i class="bi bi-clock"></i>
                        <span>Розклад</span>
                    </a>
                    <a class="bs-drawer-link" asp-page="/Dashboard/AiAssistant/Index">
                        <i class="bi bi-stars"></i>
                        <span>AI-помічник</span>
                        <span class="bs-mini-badge">Pro</span>
                    </a>
                    <a class="bs-drawer-link" asp-page="/Dashboard/Subscription/Index">
                        <i class="bi bi-credit-card"></i>
                        <span>Підписка</span>
                    </a>
                    <a class="bs-drawer-link" asp-page="/Dashboard/Settings/Index">
                        <i class="bi bi-gear"></i>
                        <span>Налаштування</span>
                    </a>
                </div>
            }
            else
            {
                <div class="bs-auth-card">
                    <h5 id="accountMenuLabel">Почати з BookSlot</h5>
                    <p>Створи сторінку запису, підключи AI-помічника і керуй клієнтами з дашборду.</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-primary flex-fill" asp-area="Identity" asp-page="/Account/Register">Реєстрація</a>
                        <a class="btn btn-outline-secondary flex-fill" asp-area="Identity" asp-page="/Account/Login">Увійти</a>
                    </div>
                </div>

                <div class="bs-drawer-section">
                    <a class="bs-drawer-link" href="/#pricing">
                        <i class="bi bi-tags"></i>
                        <span>Тарифи</span>
                    </a>
                    <a class="bs-drawer-link" href="/#ai-flow">
                        <i class="bi bi-stars"></i>
                        <span>AI-помічник</span>
                    </a>
                    <a class="bs-drawer-link" href="/#ai-flow">
                        <i class="bi bi-grid"></i>
                        <span>Можливості</span>
                    </a>
                </div>
            }

            @if (isSignedIn)
            {
                <form class="mt-auto" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                    <button type="submit" class="bs-logout-button">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Вийти з акаунта</span>
                    </button>
                </form>
            }
        </div>
    </div>
    }

    @if (isDashboardReactShell)
    {
        <div id="bookslot-product-react-root"
             data-profile-initial="@profileInitial"
             data-profile-name="@profileName"></div>
    }

    @RenderBody()

    @if (!isLandingReact && !isDashboardReactShell)
    {
    <footer class="py-5 mt-4">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-5">
                    <div class="footer-brand mb-2">
                        <span class="brand-icon" aria-hidden="true"><span class="bs-brand-spark"></span></span>
                        BookSlot
                    </div>
                    <p style="font-size:.9rem">Онлайн-запис і AI-помічник для малого бізнесу. Менше повідомлень, більше записів.</p>
                </div>
                <div class="col-md-3">
                    <h6 class="text-white fw-600 mb-3">Продукт</h6>
                    <ul class="list-unstyled" style="font-size:.9rem">
                        <li class="mb-2"><a href="/#ai-flow">AI-помічник</a></li>
                        <li class="mb-2"><a href="/#ai-flow">Можливості</a></li>
                        <li class="mb-2"><a href="/#pricing">Тарифи</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white fw-600 mb-3">Контакти</h6>
                    <ul class="list-unstyled" style="font-size:.9rem">
                        <li class="mb-2"><a href="mailto:bookslot0@gmail.com"><i class="bi bi-envelope me-2"></i>bookslot0@gmail.com</a></li>
                        <li class="mb-2"><a href="https://t.me/koletvl" target="_blank"><i class="bi bi-telegram me-2"></i>Telegram</a></li>
                    </ul>
                </div>
            </div>
            <hr style="border-color:#1e293b;margin:2rem 0 1rem">
            <p class="text-center mb-0" style="font-size:.82rem">&copy; 2026 BookSlot. Всі права захищені.</p>
        </div>
    </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (isDashboardReactShell)
    {
        <script type="module" src="~/dist/assets/bookslot-product.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
