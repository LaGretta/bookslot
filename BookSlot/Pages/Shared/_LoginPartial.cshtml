@using Microsoft.AspNetCore.Identity
@using BookSlot.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link" asp-page="/Dashboard/Index">
            <i class="bi bi-speedometer2 me-1"></i> Дашборд
        </a>
    </li>
    <li class="nav-item">
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
            <button type="submit" class="btn btn-outline-secondary btn-sm">Вийти</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Увійти</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-primary btn-sm px-3" asp-area="Identity" asp-page="/Account/Register">Реєстрація</a>
    </li>
}
</ul>
