<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { background: #f4f5f7; }
    </style>
</head>
<body>
    <nav class="navbar bg-white sticky-top" style="box-shadow:0 1px 0 #E2E8F0;padding:.75rem 0">
        <div class="container" style="max-width:700px">
            <a class="navbar-brand" href="/">
                <span class="brand-icon"><i class="bi bi-calendar-check-fill"></i></span>
                <span class="brand-text">BookSlot</span>
            </a>
            <a href="/Identity/Account/Register"
               style="font-size:.85rem;font-weight:600;color:#4F46E5;text-decoration:none">
                Створити профіль →
            </a>
        </div>
    </nav>
    @RenderBody()
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
