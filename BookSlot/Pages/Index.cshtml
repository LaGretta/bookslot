@page
@model IndexModel
@using Microsoft.AspNetCore.Identity
@using BookSlot.Data
@inject SignInManager<ApplicationUser> SignInManager
@{
    ViewData["Title"] = "AI Receptionist для онлайн-запису";
    ViewData["LandingReact"] = true;
    Layout = "_Layout";
    var isLoggedIn = SignInManager.IsSignedIn(User);
}

<div id="bookslot-react-root" data-logged-in="@isLoggedIn.ToString().ToLowerInvariant()"></div>

@section Styles {
    <link rel="stylesheet" href="~/dist/assets/bookslot-landing.css" asp-append-version="true" />
}

@section Scripts {
    <script type="module" src="~/dist/assets/bookslot-landing.js" asp-append-version="true"></script>
}
