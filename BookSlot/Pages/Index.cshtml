@page
@model IndexModel
@using Microsoft.AspNetCore.Identity
@using BookSlot.Data
@inject SignInManager<ApplicationUser> SignInManager
@{
    ViewData["Title"] = "Онлайн-запис для вашого бізнесу";
    Layout = "_Layout";
    var isLoggedIn = SignInManager.IsSignedIn(User);
}

<!-- Hero -->
<section class="hero">
    <div class="container text-center">
        <h1>Онлайн-запис для<br>вашого бізнесу</h1>
        <p class="mb-4">Барбершоп, косметолог, репетитор — дайте клієнтам<br>можливість записатися 24/7 без дзвінків і мессенджерів</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            @if (isLoggedIn)
            {
                <a asp-page="/Dashboard/Index" class="btn btn-light btn-lg px-4 fw-bold">
                    Мій дашборд
                </a>
            }
            else
            {
                <a asp-page="/Account/Register" asp-area="Identity" class="btn btn-light btn-lg px-4 fw-bold">
                    Спробувати безкоштовно
                </a>
            }
            <a href="#features" class="btn btn-outline-light btn-lg px-4">
                Дізнатися більше
            </a>
        </div>
        <p class="mt-3" style="opacity:.7;font-size:.9rem">14 днів безкоштовно. Без кредитної картки.</p>
    </div>
</section>

<!-- Features -->
<section id="features" class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-2">Все що потрібно для онлайн-запису</h2>
        <p class="text-center text-muted mb-5">Налаштуйте за 10 хвилин, отримуйте клієнтів одразу</p>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="feature-icon">📅</div>
                    <h5 class="fw-bold">Розклад роботи</h5>
                    <p class="text-muted">Налаштуйте робочі години для кожного дня тижня. Клієнти бачать тільки вільні слоти.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="feature-icon">✂️</div>
                    <h5 class="fw-bold">Управління послугами</h5>
                    <p class="text-muted">Додавайте послуги з ціною та тривалістю. Клієнт обирає що йому потрібно.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="feature-icon">📩</div>
                    <h5 class="fw-bold">Email-нагадування</h5>
                    <p class="text-muted">Клієнт отримує підтвердження на пошту. Ви отримуєте сповіщення про нові записи.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="feature-icon">🔗</div>
                    <h5 class="fw-bold">Ваша унікальна сторінка</h5>
                    <p class="text-muted">Отримайте посилання виду bookslot.com/book/ваш-бізнес і діліться з клієнтами.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="feature-icon">📊</div>
                    <h5 class="fw-bold">Статистика та аналітика</h5>
                    <p class="text-muted">Бачте скільки записів, яка популярна послуга, хто відмінив запис.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card p-4">
                    <div class="feature-icon">📱</div>
                    <h5 class="fw-bold">Мобільна версія</h5>
                    <p class="text-muted">Клієнти записуються з телефону. Ви управляєте бізнесом з будь-якого пристрою.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How it works -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Як це працює?</h2>
        <div class="row g-4 align-items-center">
            <div class="col-md-4 text-center">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:70px;height:70px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:1.5rem;color:white;font-weight:800">1</div>
                <h5 class="fw-bold">Реєструєтесь</h5>
                <p class="text-muted">Створюєте акаунт і налаштовуєте профіль вашого бізнесу за 5 хвилин</p>
            </div>
            <div class="col-md-4 text-center">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:70px;height:70px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:1.5rem;color:white;font-weight:800">2</div>
                <h5 class="fw-bold">Ділитесь посиланням</h5>
                <p class="text-muted">Отримуєте унікальне посилання і розміщуєте в Instagram, Telegram або на сайті</p>
            </div>
            <div class="col-md-4 text-center">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:70px;height:70px;background:linear-gradient(135deg,#667eea,#764ba2);font-size:1.5rem;color:white;font-weight:800">3</div>
                <h5 class="fw-bold">Клієнти записуються</h5>
                <p class="text-muted">Клієнти самі обирають час, ви отримуєте сповіщення і зустрічаєте гостя</p>
            </div>
        </div>
    </div>
</section>

<!-- Pricing -->
<section id="pricing" class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-2">Прозорі ціни</h2>
        <p class="text-center text-muted mb-5">Починайте безкоштовно, масштабуйте по мірі росту</p>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="pricing-card">
                    <h4 class="fw-bold">Безкоштовно</h4>
                    <div class="pricing-price my-3">0 грн<span style="font-size:1rem;font-weight:400">/міс</span></div>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>До 30 записів/міс</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>1 послуга</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Сторінка запису</li>
                        <li class="mb-2 text-muted"><i class="bi bi-x-circle me-2"></i>Email-сповіщення</li>
                    </ul>
                    <a asp-page="/Account/Register" asp-area="Identity" class="btn btn-outline-primary w-100">Почати</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="pricing-card featured">
                    <div class="badge bg-warning text-dark mb-2">Найпопулярніший</div>
                    <h4 class="fw-bold">Basic</h4>
                    <div class="pricing-price my-3">299 грн<span style="font-size:1rem;font-weight:400">/міс</span></div>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2"><i class="bi bi-check-circle-fill me-2" style="color:#a5f3a5"></i>До 200 записів/міс</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill me-2" style="color:#a5f3a5"></i>Необмежені послуги</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill me-2" style="color:#a5f3a5"></i>Email-сповіщення</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill me-2" style="color:#a5f3a5"></i>Статистика</li>
                    </ul>
                    <a asp-page="/Account/Register" asp-area="Identity" class="btn btn-light w-100 fw-bold">Спробувати 14 днів безкоштовно</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="pricing-card">
                    <h4 class="fw-bold">Pro</h4>
                    <div class="pricing-price my-3">599 грн<span style="font-size:1rem;font-weight:400">/міс</span></div>
                    <ul class="list-unstyled text-start mb-4">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Необмежені записи</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Необмежені послуги</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Email + SMS</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Пріоритетна підтримка</li>
                    </ul>
                    <a asp-page="/Account/Register" asp-area="Identity" class="btn btn-outline-primary w-100">Обрати Pro</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5" style="background:linear-gradient(135deg,#667eea,#764ba2)">
    <div class="container text-center text-white">
        <h2 class="fw-bold mb-3">Готові отримувати більше клієнтів?</h2>
        <p class="mb-4" style="opacity:.9">Приєднуйтесь до сотень бізнесів, які вже використовують BookSlot</p>
        @if (isLoggedIn)
        {
            <a asp-page="/Dashboard/Index" class="btn btn-light btn-lg px-5 fw-bold">
                Мій дашборд <i class="bi bi-arrow-right ms-2"></i>
            </a>
        }
        else
        {
            <a asp-page="/Account/Register" asp-area="Identity" class="btn btn-light btn-lg px-5 fw-bold">
                Почати безкоштовно <i class="bi bi-arrow-right ms-2"></i>
            </a>
        }
    </div>
</section>
