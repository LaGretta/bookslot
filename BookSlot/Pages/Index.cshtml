<!-- ══ CTA ════════════════════════════════════════════════════════════ -->
<section class="lp-cta-outer">
    <div class="container">
        <div class="lp-cta-box">
            <h2 class="lp-cta-h">Готові перестати<br>відповідати на дзвінки?</h2>
            <p class="lp-cta-p">Приєднуйтесь до бізнесів, які вже автоматизували запис і витрачають час на клієнтів, а не на телефон.</p>
            @if (isLoggedIn)
            {
                <a asp-page="/Dashboard/Index" class="lp-btn-prim">
                    <i class="bi bi-grid me-2"></i>Мій дашборд
                </a>
            }
            else
            {
                <a asp-page="/Account/Register" asp-area="Identity" class="lp-btn-prim" style="font-size:1rem;padding:.9rem 2.25rem">
                    Почати безкоштовно <i class="bi bi-arrow-right ms-2"></i>
                </a>
            }
        </div>
    </div>
</section>

@section Scripts {
<script>
// Glass navbar
(function(){
  var nav = document.getElementById('main-nav');
  function upd(){ nav.classList.toggle('lp-scrolled', window.scrollY > 60); }
  window.addEventListener('scroll', upd, { passive: true });
  upd();
})();

// 3D tilt on pricing cards
document.querySelectorAll('.lp-p-card').forEach(function(card){
  var f = card.classList.contains('lp-featured');
  card.addEventListener('mousemove', function(e){
    var r = card.getBoundingClientRect();
    var x = e.clientX - r.left  - r.width/2;
    var y = e.clientY - r.top   - r.height/2;
    var rx = (-y / (r.height/2)) * 13;
    var ry = ( x / (r.width/2))  * 13;
    card.style.transition = 'transform .1s ease, box-shadow .1s ease';
    card.style.transform  = 'translateY('+(f?-10:-18)+'px) scale('+(f?1.08:1.05)+') rotateX('+rx+'deg) rotateY('+ry+'deg)';
    card.style.boxShadow  = f
      ? '0 70px 120px rgba(79,70,229,.65), 0 0 100px rgba(79,70,229,.28)'
      : '0 40px 90px rgba(79,70,229,.18)';
  });
  card.addEventListener('mouseleave', function(){
    card.style.transition = 'transform .4s cubic-bezier(.23,1,.32,1), box-shadow .4s ease';
    card.style.transform  = f ? 'scale(1.04)' : '';
    card.style.boxShadow  = f ? '0 30px 70px rgba(79,70,229,.45)' : '';
  });
});
</script>
}
