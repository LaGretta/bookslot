@page
@model IndexModel
@using Microsoft.AspNetCore.Identity
@using BookSlot.Data
@inject SignInManager<ApplicationUser> SignInManager
@{
    ViewData["Title"] = "Онлайн-запис для вашого бізнесу";
    Layout = "_Layout";
    var isLoggedIn = SignInManager.IsSignedIn(User);
}

<style>
/* ── Glass navbar on landing page ── */
#main-nav { background: transparent !important; box-shadow: none !important; border-bottom: none !important; }
#main-nav.lp-scrolled { background: rgba(255,255,255,.92) !important; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0 1px 0 #e2e8f0 !important; }
#main-nav:not(.lp-scrolled) .nav-link { color: rgba(255,255,255,.8) !important; }
#main-nav:not(.lp-scrolled) .nav-link:hover { color: #fff !important; background: rgba(255,255,255,.08) !important; }
#main-nav:not(.lp-scrolled) .navbar-toggler { border-color: rgba(255,255,255,.3) !important; }
#main-nav:not(.lp-scrolled) .navbar-toggler-icon { filter: invert(1); }
#main-nav:not(.lp-scrolled) .btn-outline-primary { border-color: rgba(255,255,255,.3) !important; color: rgba(255,255,255,.9) !important; }
#main-nav:not(.lp-scrolled) .btn-outline-primary:hover { background: rgba(255,255,255,.12) !important; border-color: rgba(255,255,255,.5) !important; }
#main-nav:not(.lp-scrolled) .btn-primary { background: rgba(255,255,255,.12) !important; border-color: rgba(255,255,255,.25) !important; }
</style>

<!-- ══ HERO ══════════════════════════════════════════════════════════ -->
<section class="lp-hero">
    <div class="lp-blob1"></div>
    <div class="lp-blob2"></div>
    <div class="container position-relative" style="z-index:2">
        <div class="text-center">
            <div class="lp-badge">
                <span class="lp-dot"></span>
                Запуск за 5 хвилин · Без технічних знань
            </div>
            <h1 class="lp-h1">Клієнти записуються <em class="lp-em">самі.</em><br>Ви просто зустрічаєте.</h1>
            <p class="lp-sub">BookSlot — онлайн-запис для барбершопів, косметологів,<br class="d-none d-md-block"> репетиторів та інших малих бізнесів. Замість дзвінків — посилання.</p>
            <div class="lp-actions">
                @if (isLoggedIn)
                {
                    <a asp-page="/Dashboard/Index" class="lp-btn-prim">
                        <i class="bi bi-grid me-2"></i>Мій дашборд
                    </a>
                }
                else
                {
                    <a asp-page="/Account/Register" asp-area="Identity" class="lp-btn-prim">
                        Спробувати безкоштовно <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    <a href="#features" class="lp-btn-sec"><i class="bi bi-play-circle me-2"></i>Як це працює</a>
                }
            </div>
            <div class="lp-trust">
                <i class="bi bi-gift"></i> Є безкоштовний план &nbsp;·&nbsp;
                <i class="bi bi-lightning-charge"></i> Готово за 5 хв &nbsp;·&nbsp;
                <i class="bi bi-shield-check"></i> Безпечна оплата
            </div>
            <div class="lp-stats">
                <div class="lp-stat"><div class="lp-stat-n">200+</div><div class="lp-stat-l">Акаунтів</div></div>
                <div class="lp-stat"><div class="lp-stat-n">15 000+</div><div class="lp-stat-l">Записів на місяць</div></div>
                <div class="lp-stat"><div class="lp-stat-n">4.9 ★</div><div class="lp-stat-l">Середня оцінка</div></div>
            </div>
        </div>
    </div>
</section>

