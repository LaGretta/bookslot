@page
@model IndexModel
@using Microsoft.AspNetCore.Identity
@using BookSlot.Data
@inject SignInManager<ApplicationUser> SignInManager
@{
    ViewData["Title"] = "AI Receptionist для онлайн-запису";
    Layout = "_Layout";
    var isLoggedIn = SignInManager.IsSignedIn(User);
}

<section class="ai-hero">
    <div class="container">
        <div class="ai-hero-grid">
            <div class="ai-hero-copy">
                <div class="ai-kicker">
                    <i class="bi bi-stars"></i>
                    Новий крок BookSlot
                </div>
                <h1>Онлайн-запис + AI Receptionist для малого бізнесу</h1>
                <p class="ai-lead">
                    BookSlot допомагає клієнтам записуватись самостійно, а AI Receptionist відповідає в Telegram,
                    уточнює послугу, дату, час і готує запис для власника.
                </p>
                <div class="ai-hero-actions">
                    @if (isLoggedIn)
                    {
                        <a asp-page="/Dashboard/AiAssistant/Index" class="ai-btn-primary">
                            <i class="bi bi-stars"></i> Відкрити AI Receptionist
                        </a>
                        <a asp-page="/Dashboard/Index" class="ai-btn-secondary">Дашборд</a>
                    }
                    else
                    {
                        <a asp-page="/Account/Register" asp-area="Identity" class="ai-btn-primary">
                            Спробувати BookSlot <i class="bi bi-arrow-right"></i>
                        </a>
                        <a href="#ai" class="ai-btn-secondary">Подивитись AI flow</a>
                    }
                </div>
                <div class="ai-proof">
                    <span><i class="bi bi-link-45deg"></i> Посилання для запису</span>
                    <span><i class="bi bi-telegram"></i> Telegram AI MVP</span>
                    <span><i class="bi bi-shield-check"></i> Безпечне підтвердження власником</span>
                </div>
            </div>

            <div class="ai-flow-demo" aria-label="AI Receptionist booking flow preview">
                <div class="ai-chat-top">
                    <div>
                        <strong>BookSlot AI</strong>
                        <span>Telegram Receptionist</span>
                    </div>
                    <i class="bi bi-telegram"></i>
                </div>

                <div class="ai-flow-stage ai-flow-booking">
                    <div class="ai-flow-label"><i class="bi bi-link-45deg"></i> Посилання BookSlot</div>
                    <div class="ai-mini-booking">
                        <div class="ai-mini-row">
                            <span>Клієнт обирає</span>
                            <strong>Манікюр</strong>
                        </div>
                        <div class="ai-mini-slots">
                            <span>14:30</span>
                            <span class="active">16:00</span>
                            <span>17:30</span>
                        </div>
                    </div>
                </div>

                <div class="ai-flow-arrow">
                    <span></span>
                    <i class="bi bi-arrow-down"></i>
                </div>

                <div class="ai-flow-stage ai-flow-telegram">
                    <div class="ai-flow-label"><i class="bi bi-telegram"></i> Telegram-розмова</div>
                    <div class="ai-message customer">Привіт, є сьогодні на манікюр о 16:00?</div>
                    <div class="ai-message assistant">Так, час вільний. Напишіть, будь ласка, ім'я та телефон.</div>
                    <div class="ai-message customer">Олена, +380...</div>
                </div>

                <div class="ai-flow-stage ai-flow-confirmed">
                    <div class="ai-draft-card">
                        <div class="ai-draft-title"><i class="bi bi-calendar2-check"></i> Запис підготовлено</div>
                        <div class="ai-draft-row"><span>Послуга</span><strong>Манікюр</strong></div>
                        <div class="ai-draft-row"><span>Час</span><strong>16:00</strong></div>
                        <div class="ai-draft-row"><span>Клієнт</span><strong>Олена</strong></div>
                        <div class="ai-flow-status"><i class="bi bi-check2-circle"></i> Готово до підтвердження</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="ai" class="ai-section">
    <div class="container">
        <div class="ai-section-head">
            <div class="ai-kicker"><i class="bi bi-robot"></i> Premium upgrade</div>
            <h2>Не просто чатбот. Віртуальна рецепція для записів.</h2>
            <p>AI не “балакає заради балачки”. Він збирає структуровані дані для запису і не створює booking, якщо бракує важливої інформації.</p>
        </div>

        <div class="ai-feature-grid">
            <div class="ai-feature">
                <i class="bi bi-chat-dots"></i>
                <h3>Відповідає клієнтам</h3>
                <p>Українською або російською, залежно від мови повідомлення клієнта.</p>
            </div>
            <div class="ai-feature">
                <i class="bi bi-ui-checks-grid"></i>
                <h3>Уточнює деталі</h3>
                <p>Послуга, дата, час, ім'я та контакт збираються окремо й обережно.</p>
            </div>
            <div class="ai-feature">
                <i class="bi bi-calendar-week"></i>
                <h3>Перевіряє слоти</h3>
                <p>AI використовує існуючу логіку BookSlot, а не обходить розклад напряму.</p>
            </div>
            <div class="ai-feature">
                <i class="bi bi-person-check"></i>
                <h3>Власник контролює</h3>
                <p>На MVP етапі запис із AI draft підтверджується вручну в dashboard.</p>
            </div>
        </div>
    </div>
</section>

<section id="features" class="ai-section ai-soft">
    <div class="container">
        <div class="ai-section-head">
            <div class="ai-kicker"><i class="bi bi-shop"></i> Для кого</div>
            <h2>Для бізнесів, де кожне повідомлення може стати записом</h2>
            <p>
                BookSlot Basic закриває простий онлайн-запис. BookSlot Pro / AI додає receptionist layer:
                клієнт пише в Telegram, а система доводить розмову до готового запису.
            </p>
        </div>

        <div class="ai-profession-marquee" aria-label="Професії та бізнеси для BookSlot">
            <div class="ai-profession-track">
                <span><i class="bi bi-scissors"></i> Барбери</span>
                <span><i class="bi bi-stars"></i> Майстри манікюру</span>
                <span><i class="bi bi-eye"></i> Брові та вії</span>
                <span><i class="bi bi-heart-pulse"></i> Масажисти</span>
                <span><i class="bi bi-shop"></i> Салони краси</span>
                <span><i class="bi bi-activity"></i> Тренери</span>
                <span><i class="bi bi-person-video3"></i> Консультанти</span>
                <span><i class="bi bi-brush"></i> Тату-майстри</span>
                <span><i class="bi bi-camera"></i> Фотографи</span>
                <span><i class="bi bi-mortarboard"></i> Репетитори</span>
                <span><i class="bi bi-scissors"></i> Барбери</span>
                <span><i class="bi bi-stars"></i> Майстри манікюру</span>
                <span><i class="bi bi-eye"></i> Брові та вії</span>
                <span><i class="bi bi-heart-pulse"></i> Масажисти</span>
                <span><i class="bi bi-shop"></i> Салони краси</span>
                <span><i class="bi bi-activity"></i> Тренери</span>
                <span><i class="bi bi-person-video3"></i> Консультанти</span>
                <span><i class="bi bi-brush"></i> Тату-майстри</span>
                <span><i class="bi bi-camera"></i> Фотографи</span>
                <span><i class="bi bi-mortarboard"></i> Репетитори</span>
            </div>
        </div>

        <div class="ai-profession-marquee reverse" aria-hidden="true">
            <div class="ai-profession-track">
                <span><i class="bi bi-calendar-heart"></i> Wellness</span>
                <span><i class="bi bi-clipboard2-pulse"></i> Локальні клініки</span>
                <span><i class="bi bi-person-heart"></i> Психологи</span>
                <span><i class="bi bi-flower1"></i> SPA</span>
                <span><i class="bi bi-gem"></i> Beauty studio</span>
                <span><i class="bi bi-lightning-charge"></i> Сервісні бізнеси</span>
                <span><i class="bi bi-calendar-heart"></i> Wellness</span>
                <span><i class="bi bi-clipboard2-pulse"></i> Локальні клініки</span>
                <span><i class="bi bi-person-heart"></i> Психологи</span>
                <span><i class="bi bi-flower1"></i> SPA</span>
                <span><i class="bi bi-gem"></i> Beauty studio</span>
                <span><i class="bi bi-lightning-charge"></i> Сервісні бізнеси</span>
            </div>
        </div>
    </div>
</section>

<section id="pricing" class="ai-section">
    <div class="container">
        <div class="ai-section-head">
            <div class="ai-kicker"><i class="bi bi-credit-card"></i> Тарифи</div>
            <h2>Basic для запису. Pro / AI для автоматизації переписок.</h2>
        </div>

        <div class="ai-pricing-grid">
            <div class="ai-plan">
                <h3>BookSlot Basic</h3>
                <div class="ai-plan-price">299 грн<span>/міс</span></div>
                <p>Онлайн-запис по посиланню для малого бізнесу.</p>
                <ul>
                    <li>Сторінка запису</li>
                    <li>Послуги, ціни, розклад</li>
                    <li>Email-підтвердження</li>
                </ul>
            </div>
            <div class="ai-plan ai-plan-featured">
                <div class="ai-plan-badge">Новий premium напрям</div>
                <h3>BookSlot Pro / AI</h3>
                <div class="ai-plan-price">599 грн<span>/міс</span></div>
                <p>AI Receptionist, який відповідає клієнтам і готує записи автоматично.</p>
                <ul>
                    <li>Telegram AI Receptionist MVP</li>
                    <li>AI conversation drafts</li>
                    <li>Dashboard review перед створенням booking</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="ai-cta">
    <div class="container">
        <div class="ai-cta-box">
            <h2>Менше повідомлень. Більше записів.</h2>
            <p>BookSlot переходить від простого booking-сайту до SaaS з AI receptionist для локальних бізнесів.</p>
            @if (isLoggedIn)
            {
                <a asp-page="/Dashboard/AiAssistant/Index" class="ai-btn-primary">Налаштувати AI Receptionist</a>
            }
            else
            {
                <a asp-page="/Account/Register" asp-area="Identity" class="ai-btn-primary">Почати зараз</a>
            }
        </div>
    </div>
</section>
