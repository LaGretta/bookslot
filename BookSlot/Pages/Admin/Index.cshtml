@page
@model BookSlot.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin";
    Layout = "_Layout";
}

<div class="container py-4" style="max-width:900px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="brand-icon" style="width:40px;height:40px;font-size:1.2rem;border-radius:12px">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <div>
            <h4 class="fw-bold mb-0">Адмін-панель</h4>
            <small class="text-muted">Управління промо-акціями</small>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-2">
            <div class="stat-card text-center">
                <div class="stat-icon mx-auto mb-2" style="background:#EEF2FF">
                    <i class="bi bi-people-fill" style="color:#4F46E5"></i>
                </div>
                <div class="fs-4 fw-bold">@Model.TotalUsers</div>
                <div class="text-muted" style="font-size:.78rem">Акаунтів</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card text-center">
                <div class="stat-icon mx-auto mb-2" style="background:#F0FDF4">
                    <i class="bi bi-shop" style="color:#16a34a"></i>
                </div>
                <div class="fs-4 fw-bold">@Model.TotalBusinesses</div>
                <div class="text-muted" style="font-size:.78rem">Бізнесів</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card text-center">
                <div class="stat-icon mx-auto mb-2" style="background:#FFF7ED">
                    <i class="bi bi-calendar-check" style="color:#ea580c"></i>
                </div>
                <div class="fs-4 fw-bold">@Model.TotalBookings</div>
                <div class="text-muted" style="font-size:.78rem">Всього записів</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card text-center">
                <div class="stat-icon mx-auto mb-2" style="background:#FFF7ED">
                    <i class="bi bi-calendar2-week" style="color:#d97706"></i>
                </div>
                <div class="fs-4 fw-bold">@Model.BookingsThisMonth</div>
                <div class="text-muted" style="font-size:.78rem">Записів цього місяця</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card text-center">
                <div class="stat-icon mx-auto mb-2" style="background:#FDF4FF">
                    <i class="bi bi-credit-card-fill" style="color:#9333ea"></i>
                </div>
                <div class="fs-4 fw-bold">@Model.PaidSubscriptions</div>
                <div class="text-muted" style="font-size:.78rem">Оплачених підписок</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card text-center">
                <div class="stat-icon mx-auto mb-2" style="background:#FFF7ED">
                    <i class="bi bi-gift-fill" style="color:#ea580c"></i>
                </div>
                <div class="fs-4 fw-bold">@Model.PromoSubscriptions</div>
                <div class="text-muted" style="font-size:.78rem">Акційних (сторіс)</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card text-center">
                <div class="stat-icon mx-auto mb-2" style="background:#ECFDF5">
                    <i class="bi bi-person-plus-fill" style="color:#059669"></i>
                </div>
                <div class="fs-4 fw-bold">@Model.NewUsersThisWeek</div>
                <div class="text-muted" style="font-size:.78rem">Нових за 7 днів</div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]</div>
    }

    <!-- Owner subscription tools -->
    <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #16a34a !important;border-radius:12px">
        <div class="card-body p-4">
            <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-3">
                <div>
                    <h6 class="fw-bold mb-1">
                        <i class="bi bi-person-gear me-2 text-success"></i>Моя підписка
                    </h6>
                    <p class="text-muted small mb-0">
                        Цей блок працює тільки для <strong>sashagutsul2014@gmail.com</strong> і змінює підписку тільки твого бізнесу.
                    </p>
                </div>
                <span class="badge bg-success px-3 py-2">@Model.OwnerPlanLabel</span>
            </div>

            @if (!Model.OwnerHasBusiness)
            {
                <div class="alert alert-warning mb-0">
                    Спочатку створи бізнес у Dashboard → Налаштування, тоді тут можна буде видати собі тариф.
                </div>
            }
            else
            {
                <div class="mb-3 small text-muted">
                    Бізнес: <strong class="text-dark">@Model.OwnerBusinessName</strong>
                </div>

                <form method="post" asp-page-handler="SetOwnerPlan" class="row g-2 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold text-muted">Видати собі тариф</label>
                        <select name="plan" class="form-select">
                            <option value="Free">Free — безкоштовний</option>
                            <option value="Basic">Basic — 299 грн/міс</option>
                            <option value="Pro">Pro AI — найкращий тариф</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-success w-100" type="submit"
                                onclick="return confirm('Змінити тариф тільки для твого акаунта?')">
                            <i class="bi bi-check2-circle me-1"></i> Застосувати
                        </button>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-danger w-100" type="submit"
                                formaction="?handler=ClearOwnerPlan"
                                onclick="return confirm('Забрати підписку і повернути твій акаунт на Free?')">
                            <i class="bi bi-x-circle me-1"></i> Забрати
                        </button>
                    </div>
                </form>

                <div class="form-text mt-2">
                    Pro AI тут технічно зберігається як backend-план <code>Pro</code>, щоб не ламати Stripe і існуючу логіку.
                </div>
            }
        </div>
    </div>

    <!-- Promo info -->
    <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid var(--primary) !important;border-radius:12px">
        <div class="card-body p-4">
            <h6 class="fw-bold mb-1"><i class="bi bi-megaphone me-2 text-primary"></i>Акція "Запіарь — отримай 7 днів Basic"</h6>
            <p class="text-muted small mb-0">Клієнт скидає фото сторіс у Telegram → ти знаходиш його email тут → натискаєш "Активувати акцію". Одна активація на акаунт.</p>
        </div>
    </div>

    <!-- Search -->
    <form method="get" class="mb-3">
        <div class="input-group">
            <input name="search" class="form-control" placeholder="Пошук по email..." value="@Model.SearchEmail" />
            <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(Model.SearchEmail))
            {
                <a class="btn btn-outline-secondary" asp-page="/Admin/Index">Скинути</a>
            }
        </div>
    </form>

    @if (Model.SelectedUserProfile != null)
    {
        var profile = Model.SelectedUserProfile;
        var profilePlanLabel = profile.Plan switch {
            BookSlot.Models.SubscriptionPlan.Basic => "Basic",
            BookSlot.Models.SubscriptionPlan.Pro   => "Pro AI",
            _ => "Free"
        };
        var profilePlanBadge = profile.Plan switch {
            BookSlot.Models.SubscriptionPlan.Basic => "bg-primary",
            BookSlot.Models.SubscriptionPlan.Pro   => "bg-success",
            _ => "bg-secondary"
        };

        <div class="card border-0 shadow-sm mb-4" style="border-left:4px solid #4F46E5 !important;border-radius:12px">
            <div class="card-body p-4">
                <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">
                            <i class="bi bi-person-vcard me-2 text-primary"></i>Профіль акаунта
                        </h5>
                        <div class="text-muted small">@profile.UserId</div>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="badge @profilePlanBadge px-3 py-2">@profilePlanLabel</span>
                        <a class="btn btn-sm btn-outline-secondary"
                           asp-page="/Admin/Index"
                           asp-route-search="@Model.SearchEmail">
                            <i class="bi bi-x-lg me-1"></i>Закрити
                        </a>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 rounded-3 bg-light h-100">
                            <div class="text-muted small mb-1">Email</div>
                            <div class="fw-semibold">@profile.Email</div>
                            <div class="small mt-2">
                                <span class="badge @(profile.EmailConfirmed ? "bg-success" : "bg-warning text-dark")">
                                    @(profile.EmailConfirmed ? "Email підтверджено" : "Email не підтверджено")
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 rounded-3 bg-light h-100">
                            <div class="text-muted small mb-1">Контакти акаунта</div>
                            <div class="fw-semibold">@(profile.FullName ?? profile.UserName ?? "Без імені")</div>
                            <div class="small text-muted mt-1">Телефон: @(profile.PhoneNumber ?? "не вказано")</div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="p-3 rounded-3 bg-light h-100">
                            <div class="text-muted small mb-1">Бізнес</div>
                            @if (profile.BusinessName != null)
                            {
                                <div class="fw-semibold">@profile.BusinessName</div>
                                <div class="small text-muted">/book/@profile.BusinessSlug</div>
                                <div class="small text-muted mt-2">Категорія: @(profile.BusinessCategory ?? "не вказано")</div>
                                <div class="small text-muted">Телефон бізнесу: @(profile.BusinessPhone ?? "не вказано")</div>
                                <div class="small text-muted">Адреса: @(profile.BusinessAddress ?? "не вказано")</div>
                                @if (!string.IsNullOrWhiteSpace(profile.BusinessDescription))
                                {
                                    <div class="small mt-2">@profile.BusinessDescription</div>
                                }
                            }
                            else
                            {
                                <div class="text-muted">Бізнес ще не створено.</div>
                            }
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="p-3 rounded-3 bg-light h-100">
                            <div class="text-muted small mb-2">Активність</div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Послуг</span><strong>@profile.ServicesCount</strong>
                            </div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Записів</span><strong>@profile.BookingsCount</strong>
                            </div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Акція</span><strong>@(profile.PromoUsed ? "використана" : "доступна")</strong>
                            </div>
                            <div class="small text-muted mt-2">
                                Останній запис:
                                @(profile.LatestBookingDate.HasValue ? profile.LatestBookingDate.Value.ToString("dd.MM.yyyy") : "немає")
                            </div>
                        </div>
                    </div>
                </div>

                @if (profile.BusinessSlug != null)
                {
                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <a class="btn btn-sm btn-primary"
                           asp-page="/Book/Index"
                           asp-route-slug="@profile.BusinessSlug"
                           target="_blank">
                            <i class="bi bi-box-arrow-up-right me-1"></i>Відкрити сторінку запису
                        </a>
                        <span class="text-muted small align-self-center">
                            Створено: @(profile.BusinessCreatedAt.HasValue ? profile.BusinessCreatedAt.Value.ToString("dd.MM.yyyy HH:mm") : "немає дати")
                        </span>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Users table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="font-size:.8rem">Email</th>
                            <th style="font-size:.8rem">Бізнес</th>
                            <th style="font-size:.8rem">Підписка</th>
                            <th style="font-size:.8rem">Акція</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.Users)
                        {
                            <tr class="@(Model.SelectedUserId == u.UserId ? "table-primary" : "")">
                                <td>
                                    <div class="fw-semibold" style="font-size:.9rem">@u.Email</div>
                                </td>
                                <td>
                                    @if (u.BusinessName != null)
                                    {
                                        <div style="font-size:.9rem">@u.BusinessName</div>
                                        <small class="text-muted">/book/@u.BusinessSlug</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Бізнес не створено</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var planLabel = u.Plan switch {
                                            BookSlot.Models.SubscriptionPlan.Basic => "Basic",
                                            BookSlot.Models.SubscriptionPlan.Pro   => "Pro AI",
                                            _ => "Free"
                                        };
                                        var badgeClass = u.Plan switch {
                                            BookSlot.Models.SubscriptionPlan.Basic => "bg-primary",
                                            BookSlot.Models.SubscriptionPlan.Pro   => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@planLabel</span>
                                    @if (u.EndDate.HasValue)
                                    {
                                        <div class="small @(u.IsExpired ? "text-danger" : "text-muted")">
                                            до @u.EndDate.Value.ToString("dd.MM.yy")
                                            @if (u.IsExpired) { <span>(прострочено)</span> }
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (u.PromoUsed)
                                    {
                                        <span class="badge bg-light text-muted border">Використано</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Доступна</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-secondary fw-semibold me-1 mb-1"
                                       asp-page="/Admin/Index"
                                       asp-route-search="@Model.SearchEmail"
                                       asp-route-userId="@u.UserId">
                                        <i class="bi bi-person-vcard me-1"></i>Профіль
                                    </a>
                                    @if (u.SubscriptionId.HasValue && !u.PromoUsed)
                                    {
                                        <form method="post" asp-page-handler="GrantPromo" style="display:inline">
                                            <input type="hidden" name="subscriptionId" value="@u.SubscriptionId" />
                                            <button class="btn btn-sm btn-primary fw-semibold mb-1"
                                                    onclick="return confirm('Активувати 7 днів Basic для @u.Email?')">
                                                <i class="bi bi-gift me-1"></i> Активувати акцію
                                            </button>
                                        </form>
                                    }
                                    else if (!u.SubscriptionId.HasValue)
                                    {
                                        <span class="text-muted small">Немає підписки</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Users.Any())
                        {
                            <tr><td colspan="5" class="text-center py-4 text-muted">Нічого не знайдено</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <p class="text-muted small mt-2">Показано до 50 останніх реєстрацій.</p>
</div>
