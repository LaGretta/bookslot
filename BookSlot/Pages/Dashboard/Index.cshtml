@page
@model BookSlot.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Дашборд";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar">
            <partial name="_DashboardNav" />
        </div>

        <div class="col-md-10 py-4 px-4">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <div>
                    <h4 class="fw-bold mb-0">Дашборд</h4>
                    <p class="text-muted mb-0">@Model.Business?.Name</p>
                </div>
                <a asp-page="/Book/Index" asp-route-slug="@Model.Business?.Slug" target="_blank" class="btn btn-outline-primary">
                    <i class="bi bi-box-arrow-up-right me-1"></i> Моя сторінка запису
                </a>
            </div>

            <div class="dashboard-ai-banner mb-4">
                <div>
                    <div class="small text-uppercase fw-bold mb-1" style="letter-spacing:.08em;color:#a5b4fc">BookSlot Pro / AI</div>
                    <h5 class="fw-bold mb-1 text-white">AI-помічник уже готується для вашого бізнесу</h5>
                    <p class="mb-0">Telegram-бот може відповідати клієнтам українською або російською, збирати дані для запису і створювати чернетку в дашборді.</p>
                </div>
                <a asp-page="/Dashboard/AiAssistant/Index" class="btn btn-light fw-bold">
                    <i class="bi bi-stars me-1"></i> Відкрити AI
                </a>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1" style="font-size:.82rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Всього записів</p>
                                <h3 class="fw-bold mb-0" style="color:var(--dark)">@Model.TotalBookings</h3>
                            </div>
                            <div class="stat-icon" style="background:var(--primary-light)">
                                <i class="bi bi-calendar-check" style="color:var(--primary)"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1" style="font-size:.82rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Цього місяця</p>
                                <h3 class="fw-bold mb-0" style="color:var(--dark)">@Model.MonthBookings</h3>
                            </div>
                            <div class="stat-icon" style="background:#ECFDF5">
                                <i class="bi bi-bar-chart-line" style="color:#10B981"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1" style="font-size:.82rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Сьогодні</p>
                                <h3 class="fw-bold mb-0" style="color:var(--dark)">@Model.TodayBookings</h3>
                            </div>
                            <div class="stat-icon" style="background:#FEF3C7">
                                <i class="bi bi-clock" style="color:#D97706"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="text-muted mb-1" style="font-size:.82rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Послуг</p>
                                <h3 class="fw-bold mb-0" style="color:var(--dark)">@Model.ServicesCount</h3>
                            </div>
                            <div class="stat-icon" style="background:#FDF2F8">
                                <i class="bi bi-scissors" style="color:#9333EA"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold mb-0">Останні записи</h6>
                        <a asp-page="/Dashboard/Bookings/Index" class="btn btn-sm btn-outline-primary">Всі записи</a>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (!Model.RecentBookings.Any())
                    {
                        <div class="text-center py-5">
                            <div class="mb-3" style="font-size:2.5rem"><i class="bi bi-calendar2-plus text-primary"></i></div>
                            <h6 class="fw-bold text-dark">Ще немає записів</h6>
                            <p class="text-muted mb-3">Поділіться посиланням або протестуйте AI-помічника у Telegram.</p>
                            <div class="input-group mx-auto" style="max-width:420px">
                                <input id="dashLink" type="text" class="form-control form-control-sm"
                                       value="https://bookslot-production-8bbb.up.railway.app/book/@Model.Business?.Slug"
                                       readonly />
                                <button class="btn btn-primary btn-sm" onclick="copyDashLink(event)">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Клієнт</th>
                                        <th>Послуга</th>
                                        <th>Дата/час</th>
                                        <th>Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var b in Model.RecentBookings)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@b.ClientName</div>
                                                <small class="text-muted">@b.ClientPhone</small>
                                            </td>
                                            <td>@b.Service.Name</td>
                                            <td>@b.BookingDate.ToString("dd.MM.yyyy") о @b.StartTime.ToString(@"hh\:mm")</td>
                                            <td>
                                                <span class="badge @GetBadgeClass(b.Status)">@GetStatusLabel(b.Status)</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function copyDashLink(event) {
    const val = document.getElementById('dashLink')?.value;
    if (!val) return;
    navigator.clipboard.writeText(val).then(() => {
        const btn = event.target.closest('button');
        btn.innerHTML = '<i class="bi bi-check-lg"></i>';
        setTimeout(() => btn.innerHTML = '<i class="bi bi-clipboard"></i>', 2000);
    });
}
</script>
}

@functions {
    string GetBadgeClass(BookSlot.Models.BookingStatus s) => s switch {
        BookSlot.Models.BookingStatus.Confirmed => "bg-info text-dark",
        BookSlot.Models.BookingStatus.Completed => "bg-success",
        BookSlot.Models.BookingStatus.Cancelled => "bg-danger",
        _ => "bg-warning text-dark"
    };
    string GetStatusLabel(BookSlot.Models.BookingStatus s) => s switch {
        BookSlot.Models.BookingStatus.Confirmed => "Підтверджено",
        BookSlot.Models.BookingStatus.Completed => "Завершено",
        BookSlot.Models.BookingStatus.Cancelled => "Скасовано",
        _ => "Очікує"
    };
}
