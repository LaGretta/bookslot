@page
@model BookSlot.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Центр";
    var businessName = Model.Business?.Name ?? "Ваш бізнес";
    var bookingLink = $"{Request.Scheme}://{Request.Host}/Book/{Model.Business?.Slug}";
    var timelineBookings = Model.RecentBookings
        .OrderByDescending(b => b.BookingDate)
        .ThenBy(b => b.StartTime)
        .Take(5)
        .ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard-ops.css" asp-append-version="true" />
}

<section class="ops-shell">
    <div class="ops-layout">
        <aside class="ops-sidebar" aria-label="Навігація кабінету">
            <div class="ops-sidebar-head">
                <div class="ops-business-chip">
                    <span class="ops-orb">✶</span>
                    <div class="min-w-0">
                        <div class="ops-business-name">@businessName</div>
                        <div class="ops-business-meta">операційний центр</div>
                    </div>
                </div>
            </div>
            <partial name="_DashboardNav" />
        </aside>

        <main class="ops-main">
            <header class="ops-hero">
                <div class="ops-hero-inner">
                    <div>
                        <div class="ops-kicker">// сьогодні у фокусі</div>
                        <h1 class="ops-title">Керуйте записами без хаосу.</h1>
                        <p class="ops-subtitle">
                            Тут видно темп бізнесу: нові записи, активні послуги, швидке посилання для клієнтів і найближчі бронювання.
                        </p>
                    </div>
                    <div class="ops-actions">
                        <a asp-page="/Book/Index" asp-route-slug="@Model.Business?.Slug" target="_blank" class="ops-button">
                            <i class="bi bi-box-arrow-up-right"></i>
                            Сторінка запису
                        </a>
                        <a asp-page="/Dashboard/Bookings/Index" class="ops-button-soft">
                            <i class="bi bi-calendar-week"></i>
                            Всі записи
                        </a>
                    </div>
                </div>
            </header>

            <section class="ops-grid" aria-label="Статистика">
                <article class="ops-card ops-card-glow ops-stat">
                    <div class="ops-card-pad">
                        <div class="ops-stat-label">Всього записів</div>
                        <div class="ops-stat-value">@Model.TotalBookings</div>
                        <div class="ops-stat-foot">вся історія клієнтів</div>
                    </div>
                </article>
                <article class="ops-card ops-card-glow ops-stat">
                    <div class="ops-card-pad">
                        <div class="ops-stat-label">Цього місяця</div>
                        <div class="ops-stat-value">@Model.MonthBookings</div>
                        <div class="ops-stat-foot">поточний темп</div>
                    </div>
                </article>
                <article class="ops-card ops-card-glow ops-stat">
                    <div class="ops-card-pad">
                        <div class="ops-stat-label">Сьогодні</div>
                        <div class="ops-stat-value">@Model.TodayBookings</div>
                        <div class="ops-stat-foot">живий день</div>
                    </div>
                </article>
                <article class="ops-card ops-card-glow ops-stat">
                    <div class="ops-card-pad">
                        <div class="ops-stat-label">Послуги</div>
                        <div class="ops-stat-value">@Model.ServicesCount</div>
                        <div class="ops-stat-foot">доступно клієнтам</div>
                    </div>
                </article>
            </section>

            <section class="ops-grid">
                <article class="ops-card ops-card-glow ops-span-7">
                    <div class="ops-card-pad">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <h2 class="ops-panel-title">Найближчий ритм</h2>
                                <p class="ops-panel-copy">Останні записи зібрані як робоча стрічка, щоб швидко зрозуміти завантаження.</p>
                            </div>
                            <span class="ops-badge"><i class="bi bi-activity"></i> live</span>
                        </div>

                        @if (!timelineBookings.Any())
                        {
                            <div class="ops-empty">
                                <div class="ops-empty-icon"><i class="bi bi-calendar2-plus"></i></div>
                                <h3 class="ops-panel-title">Ще немає записів</h3>
                                <p class="ops-panel-copy">Поділіться посиланням, щоб перші клієнти могли записатися самостійно.</p>
                                <div class="ops-link-copy">
                                    <input id="dashLink" type="text" value="@bookingLink" readonly />
                                    <button type="button" class="ops-button" onclick="copyOpsInput('dashLink', this)">
                                        <i class="bi bi-clipboard"></i>
                                        Копіювати
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="ops-timeline">
                                @for (var i = 0; i < 6; i++)
                                {
                                    <div class="ops-time-row" style="top:@(i * 72 + 8)px"><span>@(8 + i):00</span></div>
                                }
                                @foreach (var booking in timelineBookings)
                                {
                                    <div class="ops-event" style="top:@EventTop(booking.StartTime)px">
                                        <div class="d-flex justify-content-between gap-2">
                                            <strong>@booking.ClientName</strong>
                                            <span class="ops-badge @GetBadgeClass(booking.Status)">@GetStatusLabel(booking.Status)</span>
                                        </div>
                                        <small>
                                            @booking.Service.Name · @booking.BookingDate.ToString("dd.MM") · @booking.StartTime.ToString(@"hh\:mm")-@booking.EndTime.ToString(@"hh\:mm")
                                        </small>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </article>

                <article class="ops-card ops-card-glow ops-span-5">
                    <div class="ops-card-pad">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <h2 class="ops-panel-title">Операційна стрічка</h2>
                                <p class="ops-panel-copy">Короткий зріз того, що щойно відбувалося у записах.</p>
                            </div>
                            <a asp-page="/Dashboard/AiAssistant/Index" class="ops-icon-button" title="AI-помічник">
                                <i class="bi bi-stars"></i>
                            </a>
                        </div>

                        <div class="ops-inbox">
                            @if (!Model.RecentBookings.Any())
                            {
                                <div class="ops-inbox-item">
                                    <span class="ops-badge">старт</span>
                                    <p>Скопіюйте посилання на сторінку запису й додайте його в Instagram, Telegram або сайт.</p>
                                </div>
                                <div class="ops-link-copy">
                                    <input id="dashLinkSide" type="text" value="@bookingLink" readonly />
                                    <button type="button" class="ops-icon-button" onclick="copyOpsInput('dashLinkSide', this)" title="Копіювати">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                </div>
                            }
                            else
                            {
                                @foreach (var booking in Model.RecentBookings.Take(5))
                                {
                                    <div class="ops-inbox-item">
                                        <div class="d-flex justify-content-between gap-2">
                                            <strong>@booking.ClientName</strong>
                                            <span class="ops-badge @GetBadgeClass(booking.Status)">@GetStatusLabel(booking.Status)</span>
                                        </div>
                                        <p>@booking.Service.Name на @booking.BookingDate.ToString("dd.MM.yyyy") о @booking.StartTime.ToString(@"hh\:mm")</p>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </article>
            </section>
        </main>
    </div>
</section>

@section Scripts {
    <script src="~/js/dashboard-ops.js" asp-append-version="true"></script>
}

@functions {
    int EventTop(TimeSpan start)
    {
        var minutes = (start - TimeSpan.FromHours(8)).TotalMinutes;
        var top = (int)(minutes / 60 * 72) + 8;
        return Math.Max(8, Math.Min(360, top));
    }

    string GetBadgeClass(BookSlot.Models.BookingStatus s) => s switch {
        BookSlot.Models.BookingStatus.Confirmed => "is-confirmed",
        BookSlot.Models.BookingStatus.Completed => "is-completed",
        BookSlot.Models.BookingStatus.Cancelled => "is-cancelled",
        _ => "is-pending"
    };

    string GetStatusLabel(BookSlot.Models.BookingStatus s) => s switch {
        BookSlot.Models.BookingStatus.Confirmed => "Підтверджено",
        BookSlot.Models.BookingStatus.Completed => "Завершено",
        BookSlot.Models.BookingStatus.Cancelled => "Скасовано",
        _ => "Очікує"
    };
}
