@page
@model BookSlot.Pages.Dashboard.Subscription.IndexModel
@{
    ViewData["Title"] = "Підписка";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar"><partial name="_DashboardNav" /></div>
        <div class="col-md-10 py-4 px-4">
            <h4 class="fw-bold mb-4">Підписка</h4>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info">@TempData["Info"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <!-- Current Plan -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Поточний план</h5>
                    @if (Model.Subscription != null)
                    {
                        var label = Model.Subscription.Plan switch {
                            BookSlot.Models.SubscriptionPlan.Basic => "Basic",
                            BookSlot.Models.SubscriptionPlan.Pro   => "Pro",
                            _                                      => "Безкоштовний"
                        };
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <span class="badge fs-6 px-3 py-2"
                                  style="background:linear-gradient(135deg,#667eea,#764ba2)">@label</span>
                            @if (Model.Subscription.EndDate.HasValue)
                            {
                                <span class="text-muted">
                                    Діє до: <strong>@Model.Subscription.EndDate.Value.ToString("dd.MM.yyyy")</strong>
                                </span>
                                if (Model.Subscription.IsExpired)
                                {
                                    <span class="badge bg-danger">Прострочено — поновіть</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Безкоштовний план (30 записів/міс)</span>
                            }
                        </div>
                        <small class="text-muted mt-2 d-block">
                            Записів на місяць:
                            <strong>@(Model.Subscription.MaxBookingsPerMonth == int.MaxValue ? "Необмежено" : Model.Subscription.MaxBookingsPerMonth.ToString())</strong>
                        </small>
                    }
                </div>
            </div>

            @if (!Model.StripeConfigured)
            {
                <div class="alert alert-warning mb-4">
                    <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Stripe ще не налаштований</h6>
                    <p class="mb-1">Відкрий <code>appsettings.json</code> і заповни:</p>
                    <pre class="bg-light p-3 rounded small mb-0">"Stripe": {
  "SecretKey":     "sk_test_...",
  "WebhookSecret": "whsec_...",
  "BaseUrl":       "http://localhost:5287"
}</pre>
                </div>
            }

            <!-- Plans -->
            <h5 class="fw-bold mb-3">Обрати план</h5>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="pricing-card">
                        <h5 class="fw-bold">Basic</h5>
                        <div class="pricing-price my-3">299 грн<span style="font-size:1rem;font-weight:400">/міс</span></div>
                        <ul class="list-unstyled text-start mb-4">
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>До 200 записів/міс</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Необмежені послуги</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Email-сповіщення</li>
                        </ul>
                        @if (Model.StripeConfigured)
                        {
                            <form method="post" asp-page-handler="Subscribe">
                                <input type="hidden" name="plan" value="Basic" />
                                <button class="btn btn-primary w-100 fw-bold">
                                    <i class="bi bi-credit-card me-1"></i> Оплатити 299 грн
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary w-100" disabled>Налаштуй Stripe ↑</button>
                        }
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="pricing-card featured">
                        <h5 class="fw-bold">Pro</h5>
                        <div class="pricing-price my-3">599 грн<span style="font-size:1rem;font-weight:400">/міс</span></div>
                        <ul class="list-unstyled text-start mb-4">
                            <li class="mb-2"><i class="bi bi-check-circle-fill me-2" style="color:#a5f3a5"></i>Необмежені записи</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill me-2" style="color:#a5f3a5"></i>Необмежені послуги</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill me-2" style="color:#a5f3a5"></i>Пріоритетна підтримка</li>
                        </ul>
                        @if (Model.StripeConfigured)
                        {
                            <form method="post" asp-page-handler="Subscribe">
                                <input type="hidden" name="plan" value="Pro" />
                                <button class="btn btn-light w-100 fw-bold">
                                    <i class="bi bi-credit-card me-1"></i> Оплатити 599 грн
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-outline-light w-100" disabled>Налаштуй Stripe ↑</button>
                        }
                    </div>
                </div>
            </div>

            <div class="alert alert-light border mt-4 small">
                <i class="bi bi-shield-check me-2 text-success"></i>
                Оплата через <strong>Stripe</strong> — світовий стандарт безпеки. Підтримує Visa, Mastercard, Apple Pay, Google Pay.
            </div>
        </div>
    </div>
</div>
