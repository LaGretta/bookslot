@page
@model BookSlot.Pages.Dashboard.Subscription.IndexModel
@{
    ViewData["Title"] = "Підписка";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar"><partial name="_DashboardNav" /></div>
        <div class="col-md-10 py-4 px-4">
            <h4 class="fw-bold mb-4">Підписка</h4>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info">@TempData["Info"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <!-- Current Plan -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Поточний план</h5>
                    @if (Model.Subscription != null)
                    {
                        var label = Model.Subscription.Plan switch {
                            BookSlot.Models.SubscriptionPlan.Basic => "Basic",
                            BookSlot.Models.SubscriptionPlan.Pro   => "Pro",
                            _                                      => "Безкоштовний"
                        };
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <span class="badge fs-6 px-3 py-2"
                                  style="background:linear-gradient(135deg,#667eea,#764ba2)">@label</span>
                            @if (Model.Subscription.EndDate.HasValue)
                            {
                                <span class="text-muted">
                                    Діє до: <strong>@Model.Subscription.EndDate.Value.ToString("dd.MM.yyyy")</strong>
                                </span>
                                if (Model.Subscription.IsExpired)
                                {
                                    <span class="badge bg-danger">Прострочено — поновіть</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Безкоштовний план (30 записів/міс)</span>
                            }
                        </div>
                        <small class="text-muted mt-2 d-block">
                            Записів на місяць:
                            <strong>@(Model.Subscription.MaxBookingsPerMonth == int.MaxValue ? "Необмежено" : Model.Subscription.MaxBookingsPerMonth.ToString())</strong>
                        </small>
                    }
                </div>
            </div>

            <!-- Promo Banner -->
            @if (Model.Subscription != null && !Model.Subscription.PromoUsed)
            {
                <div class="card border-0 mb-4" style="background:linear-gradient(135deg,#1e1b4b,#4F46E5);border-radius:16px;overflow:hidden">
                    <div class="card-body p-4 text-white">
                        <div class="d-flex align-items-start gap-3 flex-wrap">
                            <div style="font-size:2.5rem;line-height:1">📸</div>
                            <div class="flex-grow-1">
                                <h5 class="fw-bold mb-1">Безкоштовно 7 днів Basic — за одне сторіс!</h5>
                                <p class="mb-3" style="opacity:.85;font-size:.95rem">
                                    Запіарь BookSlot у себе в Instagram або TikTok Stories і отримай Basic підписку на 7 днів. Безкоштовно. Одна акція на акаунт.
                                </p>
                                <ol class="mb-3 ps-3" style="opacity:.85;font-size:.9rem">
                                    <li class="mb-1">Зроби сторіс з посиланням на свою сторінку BookSlot</li>
                                    <li class="mb-1">Скинь скріншот в Telegram: <a href="https://t.me/koletvl" target="_blank" class="text-warning fw-semibold">@@koletvl</a></li>
                                    <li>Отримай 7 днів Basic протягом кількох годин 🎁</li>
                                </ol>
                                <a href="https://t.me/koletvl" target="_blank" class="btn btn-warning fw-bold px-4">
                                    <i class="bi bi-telegram me-2"></i>Написати в Telegram
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (Model.Subscription?.PromoUsed == true)
            {
                <div class="alert alert-light border d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-check-circle-fill text-success"></i>
                    <span>Ти вже скористався промо-акцією. Дякуємо за підтримку! 🙌</span>
                </div>
            }

            @if (!Model.StripeConfigured)
            {
                <div class="alert alert-warning mb-4">
                    <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Stripe ще не налаштований</h6>
                    <p class="mb-1">Відкрий <code>appsettings.json</code> і заповни:</p>
                    <pre class="bg-light p-3 rounded small mb-0">"Stripe": {
  "SecretKey":     "sk_test_...",
  "WebhookSecret": "whsec_...",
  "BaseUrl":       "http://localhost:5287"
}</pre>
                </div>
            }

            <!-- Plans -->
            <h5 class="fw-bold mb-3">Обрати план</h5>
            <div class="row g-4">
                <!-- Free reminder -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4">
                            <p class="text-muted mb-1 fw-semibold" style="font-size:.85rem;text-transform:uppercase;letter-spacing:.5px">Безкоштовно</p>
                            <div class="fs-3 fw-bold mb-3">0 грн<span class="fs-6 fw-normal text-muted">/міс</span></div>
                            <ul class="list-unstyled mb-4" style="font-size:.93rem">
                                <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill text-success mt-1"></i>До 30 записів/міс</li>
                                <li class="mb-2 d-flex gap-2 text-muted"><i class="bi bi-x-circle mt-1"></i>Email-сповіщення</li>
                                <li class="mb-2 d-flex gap-2 text-muted"><i class="bi bi-x-circle mt-1"></i>Статистика</li>
                            </ul>
                            <span class="btn btn-outline-secondary w-100 disabled">Поточний безкоштовний</span>
                        </div>
                    </div>
                </div>

                <!-- Basic -->
                <div class="col-md-4">
                    <div class="pricing-card" style="border:2px solid var(--primary)">
                        <span class="badge mb-2" style="background:var(--primary)">Найпопулярніший</span>
                        <h5 class="fw-bold">Basic</h5>
                        <div class="pricing-price my-3">299 грн<span style="font-size:1rem;font-weight:400">/міс</span></div>
                        <ul class="list-unstyled text-start mb-4" style="font-size:.93rem">
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill text-success mt-1"></i>До 200 записів/міс</li>
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill text-success mt-1"></i>Необмежені послуги</li>
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill text-success mt-1"></i>Email-сповіщення</li>
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill text-success mt-1"></i>Статистика записів</li>
                            <li class="mb-2 d-flex gap-2 text-muted"><i class="bi bi-x-circle mt-1"></i>Видалення "Powered by BookSlot"</li>
                        </ul>
                        @if (Model.StripeConfigured)
                        {
                            <form method="post" asp-page-handler="Subscribe">
                                <input type="hidden" name="plan" value="Basic" />
                                <button class="btn btn-primary w-100 fw-bold">
                                    <i class="bi bi-credit-card me-1"></i> Оплатити 299 грн
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary w-100" disabled>Незабаром</button>
                        }
                    </div>
                </div>

                <!-- Pro -->
                <div class="col-md-4">
                    <div class="pricing-card featured">
                        <span class="badge bg-warning text-dark mb-2">Максимум можливостей</span>
                        <h5 class="fw-bold">Pro</h5>
                        <div class="pricing-price my-3">599 грн<span style="font-size:1rem;font-weight:400">/міс</span></div>
                        <ul class="list-unstyled text-start mb-4" style="font-size:.93rem">
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill mt-1" style="color:#a5f3a5;flex-shrink:0"></i>Необмежені записи</li>
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill mt-1" style="color:#a5f3a5;flex-shrink:0"></i>Необмежені послуги</li>
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill mt-1" style="color:#a5f3a5;flex-shrink:0"></i>Email-сповіщення власнику та клієнту</li>
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill mt-1" style="color:#a5f3a5;flex-shrink:0"></i>Детальна статистика</li>
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill mt-1" style="color:#a5f3a5;flex-shrink:0"></i>Email-нагадування клієнту за 24 год</li>
                            <li class="mb-2 d-flex gap-2"><i class="bi bi-check-circle-fill mt-1" style="color:#a5f3a5;flex-shrink:0"></i>QR-код вашої сторінки</li>
                        </ul>
                        @if (Model.StripeConfigured)
                        {
                            <form method="post" asp-page-handler="Subscribe">
                                <input type="hidden" name="plan" value="Pro" />
                                <button class="btn btn-light w-100 fw-bold">
                                    <i class="bi bi-credit-card me-1"></i> Оплатити 599 грн
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-outline-light w-100" disabled>Незабаром</button>
                        }
                    </div>
                </div>
            </div>

            <div class="alert alert-light border mt-4 small">
                <i class="bi bi-shield-check me-2 text-success"></i>
                Оплата через <strong>Stripe</strong> — світовий стандарт безпеки. Підтримує Visa, Mastercard, Apple Pay, Google Pay.
            </div>
        </div>
    </div>
</div>
