@page
@model BookSlot.Pages.Dashboard.Subscription.IndexModel
@{
    ViewData["Title"] = "Підписка";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar"><partial name="_DashboardNav" /></div>
        <div class="col-md-10 py-4 px-4">
            <h4 class="fw-bold mb-4">Підписка</h4>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info">@TempData["Info"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <!-- Current Plan -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Поточний план</h5>
                    @if (Model.Subscription != null)
                    {
                        var label = Model.Subscription.Plan switch {
                            BookSlot.Models.SubscriptionPlan.Basic => "Basic",
                            BookSlot.Models.SubscriptionPlan.Pro   => "Pro AI",
                            _                                      => "Безкоштовний"
                        };
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <span class="badge fs-6 px-3 py-2"
                                  style="background:linear-gradient(135deg,#667eea,#764ba2)">@label</span>
                            @if (Model.Subscription.EndDate.HasValue)
                            {
                                <span class="text-muted">
                                    Діє до: <strong>@Model.Subscription.EndDate.Value.ToString("dd.MM.yyyy")</strong>
                                </span>
                                if (Model.Subscription.IsExpired)
                                {
                                    <span class="badge bg-danger">Прострочено — поновіть</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Безкоштовний план (30 записів/міс)</span>
                            }
                        </div>
                        <small class="text-muted mt-2 d-block">
                            Записів на місяць:
                            <strong>@(Model.Subscription.MaxBookingsPerMonth == int.MaxValue ? "Необмежено" : Model.Subscription.MaxBookingsPerMonth.ToString())</strong>
                        </small>
                    }
                </div>
            </div>

            <!-- Promo Banner -->
            @if (Model.Subscription != null && !Model.Subscription.PromoUsed)
            {
                <div class="mb-4" style="position:relative;border-radius:20px;overflow:hidden;background:linear-gradient(135deg,#0f0c29,#302b63,#24243e)">
                    <!-- Decorative blobs -->
                    <div style="position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:rgba(99,102,241,.25);filter:blur(40px);pointer-events:none"></div>
                    <div style="position:absolute;bottom:-30px;left:60px;width:120px;height:120px;border-radius:50%;background:rgba(168,85,247,.2);filter:blur(35px);pointer-events:none"></div>

                    <div class="p-4 p-md-5" style="position:relative">
                        <!-- Badge -->
                        <div class="mb-3">
                            <span style="background:rgba(255,215,0,.15);border:1px solid rgba(255,215,0,.35);color:#fde68a;font-size:.75rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:.3rem .85rem;border-radius:999px">
                                🎁 Обмежена акція
                            </span>
                        </div>

                        <div class="row align-items-center g-4">
                            <!-- Icon block -->
                            <div class="col-auto d-none d-md-block">
                                <div style="width:90px;height:90px;border-radius:24px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(10px);position:relative">
                                    <i class="bi bi-phone-fill" style="font-size:2.4rem;color:#a5b4fc"></i>
                                    <!-- Small camera badge -->
                                    <div style="position:absolute;bottom:-8px;right:-8px;width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,#f59e0b,#ef4444);display:flex;align-items:center;justify-content:center;border:2px solid #1e1b4b">
                                        <i class="bi bi-camera-fill" style="font-size:.8rem;color:#fff"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Text -->
                            <div class="col text-white">
                                <h4 class="fw-bold mb-1" style="font-size:clamp(1.1rem,2.5vw,1.45rem);line-height:1.25">
                                    7 днів Basic — безкоштовно.<br>
                                    <span style="color:#a5b4fc">Просто зроби сторіс.</span>
                                </h4>
                                <p class="mb-0" style="opacity:.7;font-size:.9rem;max-width:480px">
                                    Запіарь нас в Instagram або TikTok Stories і отримай Basic підписку на тиждень. Одна акція на акаунт.
                                </p>
                            </div>
                        </div>

                        <!-- Steps -->
                        <div class="row g-3 mt-3">
                            <div class="col-md-4">
                                <div style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:1rem 1.25rem">
                                    <div style="font-size:1.4rem;margin-bottom:.35rem">📱</div>
                                    <div class="text-white fw-semibold" style="font-size:.88rem">Крок 1</div>
                                    <div style="color:rgba(255,255,255,.6);font-size:.83rem">Зроби сторіс із згадкою сайту BookSlot у своєму Instagram або TikTok</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:1rem 1.25rem">
                                    <div style="font-size:1.4rem;margin-bottom:.35rem">✉️</div>
                                    <div class="text-white fw-semibold" style="font-size:.88rem">Крок 2</div>
                                    <div style="color:rgba(255,255,255,.6);font-size:.83rem">Скинь скріншот у Telegram <a href="https://t.me/koletvl" target="_blank" style="color:#fde68a;text-decoration:none;font-weight:600">@@koletvl</a></div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:14px;padding:1rem 1.25rem">
                                    <div style="font-size:1.4rem;margin-bottom:.35rem">⚡</div>
                                    <div class="text-white fw-semibold" style="font-size:.88rem">Крок 3</div>
                                    <div style="color:rgba(255,255,255,.6);font-size:.83rem">Отримай 7 днів Basic протягом кількох годин</div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <a href="https://t.me/koletvl" target="_blank"
                               style="background:linear-gradient(135deg,#6366f1,#8b5cf6);border:none;color:#fff;font-weight:700;padding:.7rem 1.8rem;border-radius:12px;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem;font-size:.95rem;box-shadow:0 4px 20px rgba(99,102,241,.4);transition:all .2s"
                               onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 25px rgba(99,102,241,.5)'"
                               onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(99,102,241,.4)'">
                                <i class="bi bi-telegram"></i> Написати в Telegram
                            </a>
                        </div>
                    </div>
                </div>
            }
            else if (Model.Subscription?.PromoUsed == true)
            {
                <div class="d-flex align-items-center gap-3 mb-4 p-3" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:14px">
                    <div style="width:40px;height:40px;border-radius:12px;background:#dcfce7;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <i class="bi bi-check2-circle" style="color:#16a34a;font-size:1.3rem"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" style="color:#15803d;font-size:.95rem">Акцію використано</div>
                        <div style="color:#166534;font-size:.85rem;opacity:.8">Дякуємо за підтримку! Ти вже отримав свої 7 днів 🙌</div>
                    </div>
                </div>
            }

            @if (!Model.StripeConfigured)
            {
                <div class="alert alert-warning mb-4">
                    <h6 class="fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Stripe ще не налаштований</h6>
                    <p class="mb-1">Відкрий <code>appsettings.json</code> і заповни:</p>
                    <pre class="bg-light p-3 rounded small mb-0">"Stripe": {
  "SecretKey":     "sk_test_...",
  "WebhookSecret": "whsec_...",
  "BaseUrl":       "http://localhost:5287"
}</pre>
                </div>
            }

            <!-- Plans -->
            <h5 class="fw-bold mb-1 mt-2">Обрати план</h5>
            <p class="text-muted small mb-0">Масштабуйте по мірі росту бізнесу. Без прихованих платежів.</p>
            <div class="lp-price-grid" style="margin-top:1.5rem">

                <!-- FREE -->
                <div class="lp-p-card">
                    <div class="lp-p-plan lp-plan-free">БЕЗКОШТОВНО</div>
                    <div class="lp-p-price">0<sub> грн/міс</sub></div>
                    <p class="lp-p-desc">Щоб почати і спробувати</p>
                    <ul class="lp-p-list">
                        <li><i class="bi bi-check-circle-fill lp-ok"></i><span>До 30 записів/міс</span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok"></i><span>Сторінка запису</span></li>
                        <li><i class="bi bi-x-circle lp-no"></i><span class="text-muted">Email-супровід записів</span></li>
                        <li><i class="bi bi-x-circle lp-no"></i><span class="text-muted">Аналітика</span></li>
                    </ul>
                    <span class="lp-btn-price lp-price-outline" style="opacity:.55;cursor:default">Поточний план</span>
                </div>

                <!-- BASIC (featured) -->
                <div class="lp-p-card lp-featured">
                    <div class="lp-p-badge">⭐ Найпопулярніший</div>
                    <div class="lp-p-plan lp-plan-basic">BASIC</div>
                    <div class="lp-p-price">299<sub> грн/міс</sub></div>
                    <p class="lp-p-desc">200 записів + email власнику</p>
                    <ul class="lp-p-list">
                        <li><i class="bi bi-check-circle-fill lp-ok-f"></i><span>До 200 записів/міс</span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok-f"></i><span>Необмежені послуги</span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok-f"></i><span>Публічна сторінка запису</span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok-f"></i><span>Email власнику про новий запис</span></li>
                    </ul>
                    @if (Model.StripeConfigured)
                    {
                        <form method="post" asp-page-handler="Subscribe">
                            <input type="hidden" name="plan" value="Basic" />
                            <button type="submit" class="lp-btn-price lp-price-white w-100" style="border:none">
                                <i class="bi bi-credit-card me-1"></i> Оплатити 299 грн
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="lp-btn-price lp-price-white" style="opacity:.6;cursor:default">Незабаром</span>
                    }
                </div>

                <!-- PRO -->
                <div class="lp-p-card">
                    <div class="lp-p-plan lp-plan-pro">PRO AI <span style="font-size:.7rem;background:#eef2ff;color:#4f46e5;border-radius:6px;padding:.1rem .4rem;vertical-align:middle">🤖</span></div>
                    <div class="lp-p-price">599<sub> грн/міс</sub></div>
                    <p class="lp-p-desc">AI + повний email-супровід</p>
                    <ul class="lp-p-list">
                        <li><i class="bi bi-stars lp-ok" style="color:#6366f1"></i><span><strong>AI-помічник у Telegram</strong></span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok"></i><span>Необмежені записи</span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok"></i><span>Необмежені послуги</span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok"></i><span>Email власнику про новий запис</span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok"></i><span>Email клієнту з деталями запису</span></li>
                        <li><i class="bi bi-check-circle-fill lp-ok"></i><span>Нагадування клієнту за 24 години</span></li>
                    </ul>
                    @if (Model.StripeConfigured)
                    {
                        <form method="post" asp-page-handler="Subscribe">
                            <input type="hidden" name="plan" value="Pro" />
                            <button type="submit" class="lp-btn-price lp-price-pout w-100" style="border:none">
                                <i class="bi bi-credit-card me-1"></i> Оплатити 599 грн
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="lp-btn-price lp-price-pout" style="opacity:.6;cursor:default">Незабаром</span>
                    }
                </div>

            </div>
            <p class="mt-3 small" style="color:#64748b">
                <i class="bi bi-shield-check" style="color:#10b981"></i>
                Оплата через <strong>Stripe</strong> — Visa, Mastercard, Apple Pay, Google Pay
            </p>
        </div>
    </div>
</div>

@section Scripts {
<script>
// 3D tilt on pricing cards (same as landing page)
document.querySelectorAll('.lp-p-card').forEach(function(card){
  var f = card.classList.contains('lp-featured');
  card.addEventListener('mousemove', function(e){
    var r = card.getBoundingClientRect();
    var x = e.clientX - r.left  - r.width/2;
    var y = e.clientY - r.top   - r.height/2;
    var rx = (-y / (r.height/2)) * 13;
    var ry = ( x / (r.width/2))  * 13;
    card.style.transition = 'transform .1s ease, box-shadow .1s ease';
    card.style.transform  = 'translateY('+(f?-10:-18)+'px) scale('+(f?1.08:1.05)+') rotateX('+rx+'deg) rotateY('+ry+'deg)';
    card.style.boxShadow  = f
      ? '0 70px 120px rgba(79,70,229,.65), 0 0 100px rgba(79,70,229,.28)'
      : '0 40px 90px rgba(79,70,229,.18)';
  });
  card.addEventListener('mouseleave', function(){
    card.style.transition = 'transform .4s cubic-bezier(.23,1,.32,1), box-shadow .4s ease';
    card.style.transform  = f ? 'scale(1.04)' : '';
    card.style.boxShadow  = f ? '0 30px 70px rgba(79,70,229,.45)' : '';
  });
});
</script>
}
