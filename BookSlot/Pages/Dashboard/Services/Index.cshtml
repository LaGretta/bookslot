@page
@model BookSlot.Pages.Dashboard.Services.IndexModel
@{
    ViewData["Title"] = "Послуги";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar">
            <partial name="_DashboardNav" />
        </div>
        <div class="col-md-10 py-4 px-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0">Послуги</h4>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addServiceModal">
                    <i class="bi bi-plus-lg me-1"></i> Додати послугу
                </button>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            @if (!Model.Services.Any())
            {
                <div class="card border-0 shadow-sm text-center py-5">
                    <div style="font-size:3rem">✂️</div>
                    <h5 class="mt-3">Ще немає послуг</h5>
                    <p class="text-muted">Додайте перші послуги, щоб клієнти могли записатися</p>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Назва</th>
                                    <th>Опис</th>
                                    <th>Тривалість</th>
                                    <th>Ціна</th>
                                    <th>Статус</th>
                                    <th>Дії</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.Services)
                                {
                                    <tr>
                                        <td class="fw-semibold">@s.Name</td>
                                        <td class="text-muted">@(s.Description ?? "—")</td>
                                        <td>@s.DurationMinutes хв</td>
                                        <td>@s.Price.ToString("N0") грн</td>
                                        <td>
                                            <span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">
                                                @(s.IsActive ? "Активна" : "Неактивна")
                                            </span>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-primary me-1"
                                                    onclick="editService(@s.Id,'@s.Name','@s.Description','@s.DurationMinutes','@s.Price')">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@s.Id" class="d-inline"
                                                  onsubmit="return confirm('Видалити послугу?')">
                                                <button class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addServiceModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Add">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Додати послугу</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Назва *</label>
                        <input name="name" class="form-control" required placeholder="напр. Стрижка чоловіча" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Опис</label>
                        <textarea name="description" class="form-control" rows="2" placeholder="Короткий опис послуги"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Тривалість (хв) *</label>
                            <input name="duration" type="number" class="form-control" value="60" min="15" step="15" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Ціна (грн) *</label>
                            <input name="price" type="number" class="form-control" value="200" min="0" step="10" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-primary">Додати</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editServiceModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Edit">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Редагувати послугу</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" id="editId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Назва *</label>
                        <input name="name" id="editName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Опис</label>
                        <textarea name="description" id="editDescription" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Тривалість (хв)</label>
                            <input name="duration" id="editDuration" type="number" class="form-control" min="15" step="15" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Ціна (грн)</label>
                            <input name="price" id="editPrice" type="number" class="form-control" min="0" step="10" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-primary">Зберегти</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function editService(id, name, description, duration, price) {
    document.getElementById('editId').value = id;
    document.getElementById('editName').value = name;
    document.getElementById('editDescription').value = description || '';
    document.getElementById('editDuration').value = duration;
    document.getElementById('editPrice').value = price;
    new bootstrap.Modal(document.getElementById('editServiceModal')).show();
}
</script>
}
