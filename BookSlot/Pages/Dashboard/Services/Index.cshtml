@page
@using System.Globalization
@using System.Text.Json
@model BookSlot.Pages.Dashboard.Services.IndexModel
@{
    ViewData["Title"] = "Послуги";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard-ops.css" asp-append-version="true" />
}

<section class="ops-shell">
    <div class="ops-layout">
        <aside class="ops-sidebar" aria-label="Навігація кабінету">
            <div class="ops-sidebar-head">
                <div class="ops-business-chip">
                    <span class="ops-orb">✶</span>
                    <div class="min-w-0">
                        <div class="ops-business-name">Послуги</div>
                        <div class="ops-business-meta">меню для клієнтів</div>
                    </div>
                </div>
            </div>
            <partial name="_DashboardNav" />
        </aside>

        <main class="ops-main">
            <header class="ops-hero">
                <div class="ops-hero-inner">
                    <div>
                        <div class="ops-kicker">// меню запису</div>
                        <h1 class="ops-title">Послуги, які легко обрати.</h1>
                        <p class="ops-subtitle">
                            Картки показують назву, ціну, тривалість і стан послуги так, як це має відчуватися в сучасному кабінеті.
                        </p>
                    </div>
                    <div class="ops-actions">
                        <button class="ops-button" data-bs-toggle="modal" data-bs-target="#addServiceModal">
                            <i class="bi bi-plus-lg"></i>
                            Додати послугу
                        </button>
                    </div>
                </div>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="ops-card mt-3">
                    <div class="ops-card-pad">
                        <span class="ops-badge is-completed"><i class="bi bi-check2-circle"></i> @TempData["Success"]</span>
                    </div>
                </div>
            }

            @if (!Model.Services.Any())
            {
                <div class="ops-card ops-empty mt-3">
                    <div class="ops-empty-icon"><i class="bi bi-scissors"></i></div>
                    <h2 class="ops-panel-title">Ще немає послуг</h2>
                    <p class="ops-panel-copy">Додайте перші послуги, щоб клієнти могли записуватися без переписок.</p>
                    <button class="ops-button mt-3" data-bs-toggle="modal" data-bs-target="#addServiceModal">
                        <i class="bi bi-plus-lg"></i>
                        Додати першу послугу
                    </button>
                </div>
            }
            else
            {
                <section class="ops-service-grid" aria-label="Список послуг">
                    @foreach (var service in Model.Services)
                    {
                        var meter = Math.Max(28, Math.Min(100, service.DurationMinutes));
                        <article class="ops-card ops-card-glow ops-service-card">
                            <div class="ops-card-pad">
                                <div class="ops-service-top">
                                    <div class="min-w-0">
                                        <span class="ops-badge @(service.IsActive ? "is-completed" : "is-cancelled")">
                                            @(service.IsActive ? "Активна" : "Неактивна")
                                        </span>
                                        <h2 class="ops-panel-title mt-2">@service.Name</h2>
                                    </div>
                                    <div class="text-end">
                                        <div class="ops-price">@service.Price.ToString("N0")</div>
                                        <small>грн</small>
                                    </div>
                                </div>

                                <p class="ops-panel-copy">
                                    @(string.IsNullOrWhiteSpace(service.Description) ? "Короткий опис ще не додано." : service.Description)
                                </p>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="ops-mini-chip"><i class="bi bi-clock"></i> @service.DurationMinutes хв</span>
                                    <span class="ops-mini-chip"><i class="bi bi-calendar2-check"></i> онлайн-запис</span>
                                </div>

                                <div class="ops-meter" aria-hidden="true">
                                    <span style="width:@meter%"></span>
                                </div>

                                <div class="ops-card-actions">
                                    <button class="ops-button-soft"
                                            onclick='editService(@service.Id, @Html.Raw(JsonSerializer.Serialize(service.Name)), @Html.Raw(JsonSerializer.Serialize(service.Description ?? "")), @service.DurationMinutes, @service.Price.ToString(CultureInfo.InvariantCulture))'>
                                        <i class="bi bi-pencil"></i>
                                        Редагувати
                                    </button>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@service.Id"
                                          onsubmit="return confirm('Видалити послугу?')">
                                        <button class="ops-icon-button" title="Видалити">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    }
                </section>
            }
        </main>
    </div>
</section>

<div class="modal fade ops-modal" id="addServiceModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Add">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Додати послугу</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Назва *</label>
                        <input name="name" class="form-control" required placeholder="Наприклад: чоловіча стрижка" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Опис</label>
                        <textarea name="description" class="form-control" rows="2" placeholder="Короткий опис послуги"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Тривалість (хв) *</label>
                            <input name="duration" type="number" class="form-control" value="60" min="15" step="15" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Ціна (грн) *</label>
                            <input name="price" type="number" class="form-control" value="200" min="0" step="10" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="ops-button-soft" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="ops-button">Додати</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade ops-modal" id="editServiceModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Edit">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Редагувати послугу</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" id="editId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Назва *</label>
                        <input name="name" id="editName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Опис</label>
                        <textarea name="description" id="editDescription" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Тривалість (хв)</label>
                            <input name="duration" id="editDuration" type="number" class="form-control" min="15" step="15" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Ціна (грн)</label>
                            <input name="price" id="editPrice" type="number" class="form-control" min="0" step="10" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="ops-button-soft" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="ops-button">Зберегти</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard-ops.js" asp-append-version="true"></script>
    <script>
        function editService(id, name, description, duration, price) {
            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editDescription').value = description || '';
            document.getElementById('editDuration').value = duration;
            document.getElementById('editPrice').value = price;
            new bootstrap.Modal(document.getElementById('editServiceModal')).show();
        }
    </script>
}
