@page
@using System.Globalization
@model BookSlot.Pages.Dashboard.Bookings.IndexModel
@{
    ViewData["Title"] = "Записи";
    var uk = CultureInfo.GetCultureInfo("uk-UA");
    var anchor = (Model.FilterDate ?? DateTime.Today).Date;
    var offset = ((int)anchor.DayOfWeek + 6) % 7;
    var weekStart = anchor.AddDays(-offset);
    var days = Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i)).ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard-ops.css" asp-append-version="true" />
}

<section class="ops-shell">
    <div class="ops-layout">
        <aside class="ops-sidebar" aria-label="Навігація кабінету">
            <div class="ops-sidebar-head">
                <div class="ops-business-chip">
                    <span class="ops-orb">✶</span>
                    <div class="min-w-0">
                        <div class="ops-business-name">Записи</div>
                        <div class="ops-business-meta">календар клієнтів</div>
                    </div>
                </div>
            </div>
            <partial name="_DashboardNav" />
        </aside>

        <main class="ops-main">
            <header class="ops-hero">
                <div class="ops-hero-inner">
                    <div>
                        <div class="ops-kicker">// робочий тиждень</div>
                        <h1 class="ops-title">Записи як календар, а не список.</h1>
                        <p class="ops-subtitle">
                            Бачите день, час, клієнта й статус одним поглядом. На телефоні записи згруповані по днях.
                        </p>
                    </div>
                    <div class="ops-actions">
                        <a asp-page="./Index" class="ops-button-soft"><i class="bi bi-arrow-clockwise"></i> Скинути фільтри</a>
                    </div>
                </div>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="ops-card mt-3">
                    <div class="ops-card-pad">
                        <span class="ops-badge is-completed"><i class="bi bi-check2-circle"></i> @TempData["Success"]</span>
                    </div>
                </div>
            }

            <div class="ops-toolbar">
                <div>
                    <h2 class="ops-panel-title">Тиждень @weekStart.ToString("dd.MM")-@weekStart.AddDays(6).ToString("dd.MM")</h2>
                    <p class="ops-panel-copy">@Model.Bookings.Count записів у поточному зрізі</p>
                </div>
                <form method="get" class="ops-filter-form">
                    <input type="date" name="date" value="@Model.FilterDate?.ToString("yyyy-MM-dd")" aria-label="Фільтр за датою" />
                    <select name="status" aria-label="Фільтр за статусом">
                        <option value="">Всі статуси</option>
                        <option value="Pending" selected="@(Model.FilterStatus == "Pending" ? "selected" : null)">Очікують</option>
                        <option value="Confirmed" selected="@(Model.FilterStatus == "Confirmed" ? "selected" : null)">Підтверджені</option>
                        <option value="Completed" selected="@(Model.FilterStatus == "Completed" ? "selected" : null)">Завершені</option>
                        <option value="Cancelled" selected="@(Model.FilterStatus == "Cancelled" ? "selected" : null)">Скасовані</option>
                    </select>
                    <button type="submit" class="ops-button"><i class="bi bi-search"></i> Показати</button>
                </form>
            </div>

            @if (!Model.Bookings.Any())
            {
                <div class="ops-card ops-empty mt-3">
                    <div class="ops-empty-icon"><i class="bi bi-calendar-x"></i></div>
                    <h2 class="ops-panel-title">Записів не знайдено</h2>
                    <p class="ops-panel-copy">Змініть фільтр або поділіться сторінкою запису з клієнтами.</p>
                </div>
            }
            else
            {
                <section class="ops-calendar-wrap" aria-label="Календар записів">
                    <div class="ops-calendar">
                        @foreach (var day in days)
                        {
                            var dayBookings = Model.Bookings
                                .Where(b => b.BookingDate.Date == day.Date)
                                .OrderBy(b => b.StartTime)
                                .ToList();

                            <article class="ops-day">
                                <div class="ops-day-head">
                                    <div>
                                        <div class="ops-day-name">@uk.TextInfo.ToTitleCase(day.ToString("ddd", uk))</div>
                                        <div class="ops-day-date">@day.ToString("dd.MM")</div>
                                    </div>
                                    <span class="ops-badge">@dayBookings.Count</span>
                                </div>
                                <div class="ops-day-body">
                                    @if (!dayBookings.Any())
                                    {
                                        <div class="ops-day-empty">Вільно</div>
                                    }
                                    @foreach (var booking in dayBookings)
                                    {
                                        <div class="ops-calendar-event" data-booking-id="@booking.Id">
                                            <div class="ops-calendar-event-top">
                                                <strong>@booking.ClientName</strong>
                                                <span class="ops-badge @GetBadgeClass(booking.Status)">@GetStatusLabel(booking.Status)</span>
                                            </div>
                                            <small>@booking.StartTime.ToString(@"hh\:mm")-@booking.EndTime.ToString(@"hh\:mm") · @booking.Service.Name</small>
                                            <small class="d-block">@booking.ClientPhone</small>
                                            @if (!string.IsNullOrWhiteSpace(booking.ClientEmail))
                                            {
                                                <small class="d-block">@booking.ClientEmail</small>
                                            }
                                            @if (booking.Status == BookSlot.Models.BookingStatus.Confirmed || booking.Status == BookSlot.Models.BookingStatus.Pending)
                                            {
                                                <div class="ops-calendar-actions">
                                                    <form method="post" asp-page-handler="Complete" asp-route-id="@booking.Id">
                                                        <button class="ops-mini-action is-success" title="Завершити">
                                                            <i class="bi bi-check-lg"></i>
                                                        </button>
                                                    </form>
                                                    <form method="post" asp-page-handler="Cancel" asp-route-id="@booking.Id"
                                                          onsubmit="return confirm('Скасувати запис?')">
                                                        <button class="ops-mini-action is-danger" title="Скасувати">
                                                            <i class="bi bi-x-lg"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section class="ops-mobile-bookings" aria-label="Мобільний календар записів">
                    @foreach (var day in days)
                    {
                        var mobileDayBookings = Model.Bookings
                            .Where(b => b.BookingDate.Date == day.Date)
                            .OrderBy(b => b.StartTime)
                            .ToList();

                        <article class="ops-mobile-day">
                            <div class="ops-mobile-day-head">
                                <div>
                                    <strong>@uk.TextInfo.ToTitleCase(day.ToString("dddd", uk))</strong>
                                    <span>@day.ToString("dd.MM")</span>
                                </div>
                                <span class="ops-badge">@mobileDayBookings.Count</span>
                            </div>

                            @if (!mobileDayBookings.Any())
                            {
                                <div class="ops-mobile-empty">На цей день записів немає</div>
                            }
                            else
                            {
                                @foreach (var booking in mobileDayBookings)
                                {
                                    <div class="ops-mobile-booking">
                                        <div class="d-flex justify-content-between gap-2">
                                            <div>
                                                <strong>@booking.ClientName</strong>
                                                <small class="d-block">@booking.ClientPhone</small>
                                                @if (!string.IsNullOrWhiteSpace(booking.ClientEmail))
                                                {
                                                    <small class="d-block">@booking.ClientEmail</small>
                                                }
                                            </div>
                                            <span class="ops-badge @GetBadgeClass(booking.Status)">@GetStatusLabel(booking.Status)</span>
                                        </div>
                                        <p class="ops-panel-copy mb-0 mt-2">
                                            @booking.Service.Name · @booking.StartTime.ToString(@"hh\:mm")-@booking.EndTime.ToString(@"hh\:mm")
                                        </p>
                                        @if (!string.IsNullOrWhiteSpace(booking.Notes))
                                        {
                                            <p class="ops-panel-copy mb-0">@booking.Notes</p>
                                        }
                                        @if (booking.Status == BookSlot.Models.BookingStatus.Confirmed || booking.Status == BookSlot.Models.BookingStatus.Pending)
                                        {
                                            <div class="ops-card-actions">
                                                <form method="post" asp-page-handler="Complete" asp-route-id="@booking.Id">
                                                    <button class="ops-button-soft" title="Завершити">
                                                        <i class="bi bi-check-lg"></i>
                                                        Завершити
                                                    </button>
                                                </form>
                                                <form method="post" asp-page-handler="Cancel" asp-route-id="@booking.Id"
                                                      onsubmit="return confirm('Скасувати запис?')">
                                                    <button class="ops-button-soft" title="Скасувати">
                                                        <i class="bi bi-x-lg"></i>
                                                        Скасувати
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </article>
                    }
                </section>
            }
        </main>
    </div>
</section>

@section Scripts {
    <script src="~/js/dashboard-ops.js" asp-append-version="true"></script>
}

@functions {
    string GetBadgeClass(BookSlot.Models.BookingStatus s) => s switch {
        BookSlot.Models.BookingStatus.Confirmed => "is-confirmed",
        BookSlot.Models.BookingStatus.Completed => "is-completed",
        BookSlot.Models.BookingStatus.Cancelled => "is-cancelled",
        _ => "is-pending"
    };

    string GetStatusLabel(BookSlot.Models.BookingStatus s) => s switch {
        BookSlot.Models.BookingStatus.Confirmed => "Підтверджено",
        BookSlot.Models.BookingStatus.Completed => "Завершено",
        BookSlot.Models.BookingStatus.Cancelled => "Скасовано",
        _ => "Очікує"
    };
}
