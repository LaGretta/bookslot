@page
@model BookSlot.Pages.Dashboard.AiAssistant.IndexModel
@{
    ViewData["Title"] = "AI-помічник";
}

<style>
    .ai-demo-phone { max-width:340px; margin:0 auto; border:1px solid #e2e8f0; border-radius:22px; overflow:hidden; box-shadow:0 18px 45px rgba(15,23,42,.16); }
    .ai-demo-top { display:flex; align-items:center; gap:.6rem; padding:.8rem 1rem; background:#17212b; }
    .ai-demo-ava { width:34px; height:34px; border-radius:50%; background:linear-gradient(135deg,#6366f1,#22d3ee); color:#fff; font-size:.72rem; font-weight:700; display:flex; align-items:center; justify-content:center; }
    .ai-demo-name { color:#fff; font-weight:600; font-size:.85rem; line-height:1.15; }
    .ai-demo-sub { color:#7d8e9e; font-size:.72rem; }
    .ai-demo-chat { padding:1rem; display:flex; flex-direction:column; gap:.45rem; height:370px; overflow:hidden; background:#0e1621; }
    .ai-demo-msg { max-width:80%; padding:.5rem .8rem; border-radius:14px; font-size:.82rem; line-height:1.3; opacity:0; transform:translateY(10px); transition:opacity .45s ease, transform .45s ease; }
    .ai-demo-msg.in  { align-self:flex-end; background:#2b5278; color:#fff; border-bottom-right-radius:4px; }
    .ai-demo-msg.out { align-self:flex-start; background:#1e2a36; color:#e7eef5; border-bottom-left-radius:4px; }
    .ai-demo-chips { display:flex; flex-wrap:wrap; gap:.35rem; align-self:flex-start; opacity:0; transform:translateY(10px); transition:opacity .45s ease, transform .45s ease; }
    .ai-demo-chips span { background:#243443; color:#8fd0ff; border:1px solid #2f4a5e; border-radius:14px; padding:.28rem .7rem; font-size:.78rem; }
    .ai-demo-done { align-self:center; background:rgba(16,185,129,.15); color:#34d399; border:1px solid rgba(16,185,129,.32); border-radius:12px; padding:.5rem .9rem; font-weight:600; font-size:.85rem; opacity:0; transform:scale(.9); transition:opacity .45s ease, transform .45s ease; margin-top:.2rem; }
    .ai-demo-show { opacity:1 !important; transform:none !important; }
</style>

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar">
            <partial name="_DashboardNav" />
        </div>

        <div class="col-md-10 py-4 px-4">

            <div class="d-flex justify-content-between align-items-start gap-3 mb-4 flex-wrap">
                <div>
                    <div class="text-uppercase fw-semibold mb-1" style="font-size:.72rem;color:#6366f1;letter-spacing:.08em">
                        AI Receptionist
                    </div>
                    <h4 class="fw-bold mb-1">AI-помічник BookSlot</h4>
                    <p class="text-muted mb-0">@Model.Business?.Name</p>
                </div>
                @if (Model.IsLive)
                {
                    <span class="badge px-3 py-2 fw-semibold" style="background:#dcfce7;color:#166534;border:1px solid #bbf7d0">
                        <i class="bi bi-check-circle-fill me-1"></i> Працює
                    </span>
                }
                else
                {
                    <span class="badge px-3 py-2 fw-semibold" style="background:#fef3c7;color:#92400e;border:1px solid #fde68a">
                        <i class="bi bi-exclamation-circle me-1"></i> Потребує налаштування
                    </span>
                }
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                </div>
            }

            @* ── Status checklist ── *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3 text-uppercase" style="font-size:.75rem;letter-spacing:.06em;color:#6366f1">
                        <i class="bi bi-list-check me-2"></i>Що потрібно для роботи
                    </h6>
                    <div class="row g-2">
                        <div class="col-sm-6 col-lg-3">
                            @if (Model.HasActiveServices)
                            {
                                <div class="d-flex align-items-center gap-2 p-2 rounded-3" style="background:#f0fdf4">
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                    <span class="small fw-semibold">Послуги (@Model.ActiveServicesCount)</span>
                                </div>
                            }
                            else
                            {
                                <a asp-page="/Dashboard/Services/Index" class="d-flex align-items-center gap-2 p-2 rounded-3 text-decoration-none" style="background:#fff7ed">
                                    <i class="bi bi-x-circle-fill" style="color:#f97316"></i>
                                    <span class="small fw-semibold" style="color:#9a3412">Додати послуги</span>
                                </a>
                            }
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            @if (Model.HasWorkingSchedule)
                            {
                                <div class="d-flex align-items-center gap-2 p-2 rounded-3" style="background:#f0fdf4">
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                    <span class="small fw-semibold">Розклад (@Model.WorkingDaysCount дн.)</span>
                                </div>
                            }
                            else
                            {
                                <a asp-page="/Dashboard/Schedule/Index" class="d-flex align-items-center gap-2 p-2 rounded-3 text-decoration-none" style="background:#fff7ed">
                                    <i class="bi bi-x-circle-fill" style="color:#f97316"></i>
                                    <span class="small fw-semibold" style="color:#9a3412">Налаштувати розклад</span>
                                </a>
                            }
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            @if (Model.SettingsInput.IsEnabled)
                            {
                                <div class="d-flex align-items-center gap-2 p-2 rounded-3" style="background:#f0fdf4">
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                    <span class="small fw-semibold">AI увімкнений</span>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-2 p-2 rounded-3" style="background:#fff7ed">
                                    <i class="bi bi-x-circle-fill" style="color:#f97316"></i>
                                    <span class="small fw-semibold" style="color:#9a3412">Увімкни AI →</span>
                                </div>
                            }
                        </div>
                        <div class="col-sm-6 col-lg-3">
                            @if (Model.PlatformBotConfigured)
                            {
                                <div class="d-flex align-items-center gap-2 p-2 rounded-3" style="background:#f0fdf4">
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                    <span class="small fw-semibold">Telegram готовий</span>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-2 p-2 rounded-3" style="background:#f1f5f9">
                                    <i class="bi bi-dash-circle" style="color:#94a3b8"></i>
                                    <span class="small fw-semibold text-muted">Telegram не готовий</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-7">

                    @* ── Share link — the heart of the feature ── *@
                    <div class="card border-0 shadow-sm mb-4" style="background:linear-gradient(135deg,#eef2ff,#faf5ff)">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div style="width:44px;height:44px;border-radius:12px;background:white;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(99,102,241,.2)">
                                    <i class="bi bi-link-45deg" style="color:#6366f1;font-size:1.4rem"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-0">Посилання на вашого AI-бота</h5>
                                    <p class="text-muted small mb-0">Дай це посилання клієнтам — і бот сам відповідатиме за вас</p>
                                </div>
                            </div>

                            @if (Model.BotLink != null)
                            {
                                <div class="input-group mb-3">
                                    <input type="text" class="form-control bg-white" id="botLink" readonly value="@Model.BotLink" style="font-weight:600">
                                    <button class="btn btn-primary" type="button" onclick="copyBotLink()">
                                        <i class="bi bi-clipboard me-1"></i> Копіювати
                                    </button>
                                </div>
                                <div class="d-flex flex-wrap gap-3 small text-muted">
                                    <span><i class="bi bi-instagram me-1"></i>Постав у Instagram bio</span>
                                    <span><i class="bi bi-chat-square-text me-1"></i>Кидай у відповідь на питання</span>
                                    <span><i class="bi bi-qr-code me-1"></i>Зроби QR-код для салону</span>
                                </div>

                                @if (!Model.IsLive)
                                {
                                    <div class="alert alert-warning d-flex align-items-center gap-2 py-2 mb-0 mt-3 small">
                                        <i class="bi bi-info-circle-fill"></i>
                                        Посилання працюватиме, коли буде увімкнено AI, додано послуги і налаштовано розклад (див. чеклист угорі).
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-light border d-flex align-items-start gap-2 mb-0 small">
                                    <i class="bi bi-tools mt-1"></i>
                                    <div>
                                        Telegram-бот платформи ще не налаштований адміністратором.
                                        Як тільки його підключать — тут зʼявиться ваше персональне посилання.
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @* ── Test AI message ── *@
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1">Спробувати самому</h5>
                                    <p class="text-muted mb-0 small">Напиши як клієнт — побачиш, що відповість бот. Запис не створюється.</p>
                                </div>
                                <span class="badge bg-light text-dark border">Тест</span>
                            </div>

                            <form method="post" asp-page-handler="TestMessage">
                                <div class="input-group mb-2">
                                    <input asp-for="TestMessage" class="form-control" placeholder="Привіт, є завтра на манікюр о 16:00?">
                                    <button type="submit" class="btn btn-primary px-3">
                                        <i class="bi bi-play-fill me-1"></i> Перевірити
                                    </button>
                                </div>
                                <span asp-validation-for="TestMessage" class="text-danger small"></span>
                            </form>

                            @if (Model.TestReply != null)
                            {
                                <div class="border rounded-3 p-3 mt-3" style="background:#f8fafc">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <div style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#4f46e5);display:flex;align-items:center;justify-content:center">
                                            <i class="bi bi-stars text-white" style="font-size:.75rem"></i>
                                        </div>
                                        <strong class="small">Відповідь бота</strong>
                                    </div>
                                    <div class="p-3 rounded-3" style="background:white;border:1px solid #e2e8f0">
                                        @Model.TestReply.MessageToCustomer
                                    </div>
                                    @if (Model.TestReply.SuggestedSlots.Any())
                                    {
                                        <div class="d-flex gap-1 flex-wrap mt-3">
                                            @foreach (var slot in Model.TestReply.SuggestedSlots)
                                            {
                                                <span class="badge bg-white text-dark border">@slot</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @* ── Animated demo: what the client sees ── *@
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-1">Ось що бачить ваш клієнт</h5>
                            <p class="text-muted small mb-3">Бот сам веде розмову — від «привіт» до готового запису</p>

                            <div class="ai-demo-phone">
                                <div class="ai-demo-top">
                                    <div class="ai-demo-ava">AI</div>
                                    <div>
                                        <div class="ai-demo-name">@(Model.Business?.Name ?? "Ваш салон")</div>
                                        <div class="ai-demo-sub">бот • онлайн</div>
                                    </div>
                                    <i class="bi bi-telegram ms-auto" style="color:#2aabee;font-size:1.2rem"></i>
                                </div>
                                <div class="ai-demo-chat" id="aiDemoChat">
                                    <div class="ai-demo-msg in"  data-step="1">Привіт! 💅</div>
                                    <div class="ai-demo-msg out" data-step="2">Вітаю! Що вас цікавить?</div>
                                    <div class="ai-demo-chips out" data-step="3">
                                        <span>Манікюр</span><span>Педикюр</span><span>Брови</span>
                                    </div>
                                    <div class="ai-demo-msg in"  data-step="4">Манікюр</div>
                                    <div class="ai-demo-msg out" data-step="5">Чудово! На завтра є вільні години:</div>
                                    <div class="ai-demo-chips out" data-step="6">
                                        <span>14:00</span><span>16:00</span><span>17:30</span>
                                    </div>
                                    <div class="ai-demo-msg in"  data-step="7">16:00</div>
                                    <div class="ai-demo-msg out" data-step="8">Запишіть, будь ласка, імʼя та телефон 🙂</div>
                                    <div class="ai-demo-msg in"  data-step="9">Олена, +380 67 123 45 67</div>
                                    <div class="ai-demo-done out" data-step="10">
                                        <i class="bi bi-check-circle-fill"></i> Запис підготовлено!
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* ── Recent conversations ── *@
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                                <h5 class="fw-bold mb-0">Останні розмови</h5>
                                <span class="badge bg-light text-dark border">@Model.RecentConversations.Count</span>
                            </div>

                            @if (!Model.RecentConversations.Any())
                            {
                                <div class="text-center py-4 text-muted">
                                    <i class="bi bi-chat-dots" style="font-size:2rem;opacity:.3;display:block;margin-bottom:.5rem"></i>
                                    <p class="small mb-0">Поки немає розмов. Поділись посиланням з клієнтами.</p>
                                </div>
                            }
                            else
                            {
                                <div class="d-grid gap-2">
                                    @foreach (var conversation in Model.RecentConversations)
                                    {
                                        <a class="border rounded-3 px-3 py-2 text-decoration-none text-dark"
                                           asp-page="/Dashboard/AiAssistant/Conversations/Details"
                                           asp-route-id="@conversation.Id">
                                            <div class="d-flex align-items-center justify-content-between gap-2">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-telegram text-primary small"></i>
                                                    <span class="fw-semibold small">@conversation.Title</span>
                                                </div>
                                                <span class="badge small" style="background:@(conversation.StatusColor)1a;color:@conversation.StatusColor">@conversation.StatusLabel</span>
                                            </div>
                                            <div class="text-muted small text-truncate mt-1">
                                                @(conversation.LastMessage ?? "Повідомлень ще немає")
                                            </div>
                                            <div class="text-muted mt-1" style="font-size:.72rem">
                                                @conversation.UpdatedAt.ToString("dd.MM.yyyy HH:mm")
                                            </div>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">

                    @* ── AI settings form ── *@
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Налаштування</h5>

                            <form method="post" asp-page-handler="SaveSettings">
                                <div class="form-check form-switch mb-4">
                                    <input asp-for="SettingsInput.IsEnabled" class="form-check-input" type="checkbox" role="switch" style="width:2.5em;height:1.4em">
                                    <label asp-for="SettingsInput.IsEnabled" class="form-check-label fw-semibold ms-2">Увімкнути AI-помічника</label>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="SettingsInput.WelcomeMessage" class="form-label small fw-semibold text-muted">Привітання для клієнта</label>
                                    <textarea asp-for="SettingsInput.WelcomeMessage" class="form-control" rows="3" maxlength="500"
                                              placeholder="Привіт! Я допоможу обрати послугу та підготувати запис."></textarea>
                                    <div class="form-text">Перше повідомлення, яке бачить клієнт</div>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="SettingsInput.BusinessDescription" class="form-label small fw-semibold text-muted">Кілька слів про ваш бізнес</label>
                                    <textarea asp-for="SettingsInput.BusinessDescription" class="form-control" rows="3" maxlength="1000"
                                              placeholder="Наприклад: beauty-студія, манікюр, брови, дружній тон…"></textarea>
                                    <div class="form-text">Допомагає боту краще відповідати</div>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="SettingsInput.ToneOfVoice" class="form-label small fw-semibold text-muted">Тон спілкування</label>
                                    <select asp-for="SettingsInput.ToneOfVoice" class="form-select">
                                        <option>Дружній, чіткий і короткий</option>
                                        <option>Преміальний і ввічливий</option>
                                        <option>Неформальний і теплий</option>
                                    </select>
                                </div>

                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-save me-1"></i> Зберегти
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function copyBotLink() {
        var input = document.getElementById('botLink');
        if (!input) return;
        input.select();
        input.setSelectionRange(0, 99999);
        navigator.clipboard.writeText(input.value).then(function () {
            var btn = event.target.closest('button');
            if (!btn) return;
            var original = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> Скопійовано';
            setTimeout(function () { btn.innerHTML = original; }, 1500);
        });
    }

    // Looping phone-chat demo
    (function () {
        var chat = document.getElementById('aiDemoChat');
        if (!chat) return;
        var steps = Array.prototype.slice.call(chat.querySelectorAll('[data-step]'));
        var startDelay = 500, gap = 1050, holdAtEnd = 2800;

        function reset() { steps.forEach(function (s) { s.classList.remove('ai-demo-show'); }); }
        function run() {
            reset();
            steps.forEach(function (s, i) {
                setTimeout(function () {
                    s.classList.add('ai-demo-show');
                    chat.scrollTop = chat.scrollHeight;
                }, startDelay + i * gap);
            });
            setTimeout(run, startDelay + steps.length * gap + holdAtEnd);
        }
        run();
    })();
</script>
}
