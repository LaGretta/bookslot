@page
@model BookSlot.Pages.Dashboard.Schedule.IndexModel
@{
    ViewData["Title"] = "Розклад";
    var days = new[] { "Неділя","Понеділок","Вівторок","Середа","Четвер","П'ятниця","Субота" };
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar">
            <partial name="_DashboardNav" />
        </div>
        <div class="col-md-10 py-4 px-4">
            <h4 class="fw-bold mb-4">Розклад роботи</h4>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <p class="text-muted mb-4">Встановіть робочі години для кожного дня. Клієнти зможуть записуватись тільки на доступний час.</p>
                    <form method="post">
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>День</th>
                                        <th>Робочий</th>
                                        <th>Початок</th>
                                        <th>Кінець</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < 7; i++)
                                    {
                                        var schedule = Model.Schedules.FirstOrDefault(s => (int)s.DayOfWeek == i);
                                        var isWorking = schedule?.IsWorking ?? (i > 0 && i < 6);
                                        var start = schedule?.StartTime ?? new TimeSpan(9, 0, 0);
                                        var end = schedule?.EndTime ?? new TimeSpan(18, 0, 0);

                                        <tr>
                                            <td class="fw-semibold">@days[i]</td>
                                            <td>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" name="isWorking[@i]"
                                                           @(isWorking ? "checked" : "") id="day@i" />
                                                    <label class="form-check-label" for="day@i"></label>
                                                </div>
                                            </td>
                                            <td>
                                                <input type="time" name="start[@i]" class="form-control" style="width:130px"
                                                       value="@start.ToString(@"hh\:mm")" />
                                            </td>
                                            <td>
                                                <input type="time" name="end[@i]" class="form-control" style="width:130px"
                                                       value="@end.ToString(@"hh\:mm")" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-end mt-3">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-lg me-1"></i> Зберегти розклад
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
