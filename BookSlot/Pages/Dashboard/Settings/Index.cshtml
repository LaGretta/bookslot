@page
@model BookSlot.Pages.Dashboard.Settings.IndexModel
@{
    ViewData["Title"] = "Налаштування";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-2 sidebar">
            <partial name="_DashboardNav" />
        </div>
        <div class="col-md-10 py-4 px-4">
            <h4 class="fw-bold mb-4">Налаштування бізнесу</h4>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <strong>Помилка:</strong>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <span>@error.ErrorMessage</span>
                    }
                </div>
            }

            <div class="row g-4">
                <div class="col-md-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Профіль бізнесу</h5>
                            <form method="post" id="settingsForm">
                                <!-- Logo upload -->
                                <input type="hidden" name="logoBase64" id="logoBase64Input" value="" />
                                <div class="mb-4">
                                    <label class="form-label fw-semibold">Фото / Лого бізнесу</label>
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width:80px;height:80px;border-radius:50%;overflow:hidden;border:2px solid #e5e7eb;background:#f3f4f6;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                            @if (!string.IsNullOrEmpty(Model.Business?.LogoUrl))
                                            {
                                                <img id="logoPreview" src="@Model.Business.LogoUrl" style="width:100%;height:100%;object-fit:cover" />
                                                <i id="logoPlaceholder" class="bi bi-camera" style="font-size:1.8rem;color:#9ca3af;display:none"></i>
                                            }
                                            else
                                            {
                                                <img id="logoPreview" src="" style="width:100%;height:100%;object-fit:cover;display:none" />
                                                <i id="logoPlaceholder" class="bi bi-camera" style="font-size:1.8rem;color:#9ca3af"></i>
                                            }
                                        </div>
                                        <div>
                                            <label class="btn btn-outline-secondary btn-sm" for="logoFileInput">
                                                <i class="bi bi-upload me-1"></i> Обрати фото
                                            </label>
                                            <input id="logoFileInput" type="file" accept="image/jpeg,image/png,image/webp" class="d-none" onchange="handleLogoFile(this)" />
                                            <div class="text-muted small mt-1">JPG, PNG або WebP, до 2 МБ</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Назва бізнесу *</label>
                                    <input id="businessName" name="name" class="form-control"
                                           value="@Model.Business?.Name" required
                                           placeholder="напр. Барбершоп Іван"
                                           oninput="autoSlug(this.value)" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">URL-адреса (slug) *</label>
                                    <div class="input-group">
                                        <span class="input-group-text text-muted" style="font-size:.85rem">bookslot.com/book/</span>
                                        <input id="slugInput" name="slug" class="form-control"
                                               value="@Model.Business?.Slug" required
                                               placeholder="barber-ivan" pattern="[a-z0-9\-]+" />
                                    </div>
                                    <small class="text-muted">Тільки малі літери, цифри та дефіси. Якщо slug зайнятий — додайте цифру, напр. <code>barber-ivan-2</code></small>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Категорія</label>
                                    <select name="category" class="form-select">
                                        <option selected="@(Model.Business?.Category == "Барбершоп" ? "selected" : null)">Барбершоп</option>
                                        <option selected="@(Model.Business?.Category == "Косметолог" ? "selected" : null)">Косметолог</option>
                                        <option selected="@(Model.Business?.Category == "Манікюр/Педикюр" ? "selected" : null)">Манікюр/Педикюр</option>
                                        <option selected="@(Model.Business?.Category == "Масаж" ? "selected" : null)">Масаж</option>
                                        <option selected="@(Model.Business?.Category == "Репетитор" ? "selected" : null)">Репетитор</option>
                                        <option selected="@(Model.Business?.Category == "Фітнес/Тренер" ? "selected" : null)">Фітнес/Тренер</option>
                                        <option selected="@(Model.Business?.Category == "Лікар" ? "selected" : null)">Лікар</option>
                                        <option selected="@(Model.Business?.Category == "Інше" ? "selected" : null)">Інше</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Опис</label>
                                    <textarea name="description" class="form-control" rows="3"
                                              placeholder="Короткий опис вашого бізнесу для клієнтів">@Model.Business?.Description</textarea>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold">Телефон</label>
                                        <input name="phone" type="tel" class="form-control" value="@Model.Business?.Phone"
                                               placeholder="+380XXXXXXXXX" />
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold">Адреса</label>
                                        <input name="address" class="form-control" value="@Model.Business?.Address"
                                               placeholder="вул. Хрещатик 1, Київ" />
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary px-4">
                                    <i class="bi bi-check-lg me-1"></i> Зберегти
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-3">Ваша сторінка запису</h6>
                            @if (Model.Business?.Slug != null)
                            {
                                <p class="text-muted small mb-3">Поділіться цим посиланням з клієнтами в Instagram, Telegram або WhatsApp</p>
                                <div class="input-group mb-3">
                                    <input id="bookingLink" type="text" class="form-control form-control-sm"
                                           value="/book/@Model.Business.Slug" readonly />
                                    <button class="btn btn-outline-secondary btn-sm" onclick="copyLink()">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                </div>
                                <a asp-page="/Book/Index" asp-route-slug="@Model.Business.Slug" target="_blank"
                                   class="btn btn-outline-primary w-100 btn-sm">
                                    <i class="bi bi-eye me-1"></i> Переглянути
                                </a>
                            }
                            else
                            {
                                <p class="text-muted small">Збережіть профіль щоб отримати посилання</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function copyLink() {
    const link = window.location.origin + document.getElementById('bookingLink').value;
    navigator.clipboard.writeText(link).then(() => {
        const btn = event.target.closest('button');
        btn.innerHTML = '<i class="bi bi-check-lg"></i>';
        setTimeout(() => btn.innerHTML = '<i class="bi bi-clipboard"></i>', 2000);
    });
}

function handleLogoFile(input) {
    const file = input.files[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) { alert('Файл занадто великий. Максимум 2 МБ.'); return; }

    const reader = new FileReader();
    reader.onload = e => {
        const originalImg = new Image();
        originalImg.onload = () => {
            // Resize to max 300x300 using canvas
            const maxSize = 300;
            let w = originalImg.width, h = originalImg.height;
            if (w > maxSize || h > maxSize) {
                if (w > h) { h = Math.round(h * maxSize / w); w = maxSize; }
                else { w = Math.round(w * maxSize / h); h = maxSize; }
            }
            const canvas = document.createElement('canvas');
            canvas.width = w; canvas.height = h;
            canvas.getContext('2d').drawImage(originalImg, 0, 0, w, h);
            const base64 = canvas.toDataURL('image/jpeg', 0.85);

            document.getElementById('logoBase64Input').value = base64;

            const preview = document.getElementById('logoPreview');
            const placeholder = document.getElementById('logoPlaceholder');
            preview.src = base64;
            preview.style.display = 'block';
            if (placeholder) placeholder.style.display = 'none';
        };
        originalImg.src = e.target.result;
    };
    reader.readAsDataURL(file);
}

// Auto-generate slug from business name (only if slug is empty or user hasn't manually edited it)
let slugManuallyEdited = @(Model.Business?.Slug != null ? "true" : "false");
const slugInput = document.getElementById('slugInput');
if (slugInput) {
    slugInput.addEventListener('input', () => { slugManuallyEdited = true; });
}

function autoSlug(name) {
    if (slugManuallyEdited) return;
    const slug = name
        .toLowerCase()
        .replace(/[а-яёіїє]/g, c => ({'а':'a','б':'b','в':'v','г':'g','д':'d','е':'e','ж':'zh','з':'z','и':'i','й':'y','к':'k','л':'l','м':'m','н':'n','о':'o','п':'p','р':'r','с':'s','т':'t','у':'u','ф':'f','х':'kh','ц':'ts','ч':'ch','ш':'sh','щ':'shch','ь':'','ю':'yu','я':'ya','ё':'yo','і':'i','ї':'yi','є':'ye'}[c] || c))
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '')
        .substring(0, 50);
    if (slugInput) slugInput.value = slug;
}
</script>
}
