@page
@model RegisterModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="container py-5" style="max-width:480px">
    <div class="text-center mb-4">
        <a asp-page="/Index" class="text-decoration-none" style="font-size:1.5rem;font-weight:800;color:#6C63FF">
            <i class="bi bi-calendar-check"></i> BookSlot
        </a>
        <h4 class="mt-3 fw-bold">Створити акаунт</h4>
        <p class="text-muted">14 днів безкоштовно, без картки</p>
    </div>

    <div class="card border-0 shadow-sm p-4">
        <form asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label fw-semibold">Пароль</label>
                <input asp-for="Input.Password" class="form-control" placeholder="мінімум 6 символів, одна цифра" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Підтвердити пароль</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="повторіть пароль" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">
                Зареєструватись
            </button>
        </form>
    </div>

    <p class="text-center mt-3 text-muted">
        Вже є акаунт? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" style="color:#6C63FF">Увійти</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
