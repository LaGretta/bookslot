@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Відновлення пароля";
}

<div class="container py-5" style="max-width:480px">
    <div class="text-center mb-4">
        <a asp-page="/Index" class="text-decoration-none" style="font-size:1.5rem;font-weight:800;color:#6C63FF">
            <i class="bi bi-calendar-check"></i> BookSlot
        </a>
        <h4 class="mt-3 fw-bold">Відновлення пароля</h4>
        <p class="text-muted" style="font-size:.93rem">Введи свій email — надішлемо посилання для скидання</p>
    </div>

    <div class="card border-0 shadow-sm p-4">
        @if (Model.EmailSent)
        {
            <div class="text-center py-2">
                <div style="font-size:3rem;margin-bottom:1rem">📬</div>
                <h5 class="fw-bold mb-2">Перевір пошту</h5>
                <p class="text-muted" style="font-size:.93rem">
                    Якщо акаунт з таким email існує — ми надіслали посилання для скидання пароля.
                </p>
            </div>
        }
        else
        {
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">
                    Надіслати посилання
                </button>
            </form>
        }
    </div>

    <p class="text-center mt-3 text-muted">
        <a asp-page="./Login" style="color:#6C63FF">← Назад до входу</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
