@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Відновлення пароля";
}

<div class="bs-auth-shell">
    <section class="bs-auth-panel" aria-labelledby="forgot-title">
        <div class="bs-auth-head">
            <a asp-page="/Index" class="bs-auth-brand" aria-label="BookSlot">
                <span class="bs-auth-mark" aria-hidden="true"><span></span></span>
                <span>BookSlot</span>
            </a>
            <div class="bs-auth-kicker">// відновлення доступу</div>
            <h1 id="forgot-title">Відновлення пароля</h1>
            <p>Введіть email, і ми надішлемо посилання для скидання пароля.</p>
        </div>

        <div class="bs-auth-card">
            @if (Model.EmailSent)
            {
                <div class="bs-auth-success">
                    <span class="bs-auth-success-icon" aria-hidden="true"><i class="bi bi-envelope-check"></i></span>
                    <h2>Перевірте пошту</h2>
                    <p>
                        Якщо акаунт з таким email існує, ми надіслали посилання для скидання пароля.
                    </p>
                </div>
            }
            else
            {
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary bs-auth-submit w-100">
                        Надіслати посилання
                    </button>
                </form>
            }
        </div>

        <p class="bs-auth-switch">
            <a asp-page="./Login">Назад до входу</a>
        </p>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
