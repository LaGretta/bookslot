@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Новий пароль";
}

<div class="container py-5" style="max-width:480px">
    <div class="text-center mb-4">
        <a asp-page="/Index" class="text-decoration-none" style="font-size:1.5rem;font-weight:800;color:#6C63FF">
            <i class="bi bi-calendar-check"></i> BookSlot
        </a>
        <h4 class="mt-3 fw-bold">Новий пароль</h4>
    </div>

    <div class="card border-0 shadow-sm p-4">
        @if (Model.Success)
        {
            <div class="text-center py-2">
                <div style="font-size:3rem;margin-bottom:1rem">✅</div>
                <h5 class="fw-bold mb-2">Пароль змінено!</h5>
                <p class="text-muted mb-4" style="font-size:.93rem">Тепер можеш увійти з новим паролем.</p>
                <a asp-page="./Login" class="btn btn-primary px-5 fw-bold">Увійти</a>
            </div>
        }
        else
        {
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Input.Code" />
                <input type="hidden" asp-for="Input.Email" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input asp-for="Input.Email" class="form-control" readonly style="background:#f8f9fa" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-semibold">Новий пароль</label>
                    <input asp-for="Input.Password" class="form-control" type="password" placeholder="мінімум 6 символів" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Повтори пароль</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="ще раз" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Зберегти пароль</button>
            </form>
        }
    </div>

    @if (!Model.Success)
    {
        <p class="text-center mt-3 text-muted">
            <a asp-page="./Login" style="color:#6C63FF">← Назад до входу</a>
        </p>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
