@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Новий пароль";
}

<div class="bs-auth-shell">
    <section class="bs-auth-panel" aria-labelledby="reset-title">
        <div class="bs-auth-head">
            <a asp-page="/Index" class="bs-auth-brand" aria-label="BookSlot">
                <span class="bs-auth-mark" aria-hidden="true"><span></span></span>
                <span>BookSlot</span>
            </a>
            <div class="bs-auth-kicker">// новий доступ</div>
            <h1 id="reset-title">Новий пароль</h1>
            <p>Створіть новий пароль і поверніться до свого робочого простору.</p>
        </div>

        <div class="bs-auth-card">
            @if (Model.Success)
            {
                <div class="bs-auth-success">
                    <span class="bs-auth-success-icon" aria-hidden="true"><i class="bi bi-check2"></i></span>
                    <h2>Пароль змінено</h2>
                    <p>Тепер можете увійти з новим паролем.</p>
                    <a asp-page="./Login" class="btn btn-primary bs-auth-submit px-5 mt-3">Увійти</a>
                </div>
            }
            else
            {
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Input.Code" />
                    <input type="hidden" asp-for="Input.Email" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input asp-for="Input.Email" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold">Новий пароль</label>
                        <input asp-for="Input.Password" class="form-control" type="password" placeholder="мінімум 6 символів" autocomplete="new-password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Повтори пароль</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="ще раз" autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary bs-auth-submit w-100">Зберегти пароль</button>
                </form>
            }
        </div>

        @if (!Model.Success)
        {
            <p class="bs-auth-switch">
                <a asp-page="./Login">Назад до входу</a>
            </p>
        }
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
