@page
@model LoginModel
@{
    ViewData["Title"] = "Вхід";
}

<div class="container py-5" style="max-width:480px">
    <div class="text-center mb-4">
        <a asp-page="/Index" class="text-decoration-none" style="font-size:1.5rem;font-weight:800;color:#6C63FF">
            <i class="bi bi-calendar-check"></i> BookSlot
        </a>
        <h4 class="mt-3 fw-bold">Увійти в акаунт</h4>
    </div>

    <div class="card border-0 shadow-sm p-4">
        <form asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label asp-for="Input.Password" class="form-label fw-semibold mb-0">Пароль</label>
                    <a asp-page="./ForgotPassword" style="font-size:.85rem;color:#6C63FF">Забули пароль?</a>
                </div>
                <input asp-for="Input.Password" class="form-control mt-1" placeholder="ваш пароль" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Увійти</button>
        </form>
    </div>

    <p class="text-center mt-3 text-muted">
        Немає акаунту? <a asp-page="./Register" style="color:#6C63FF">Зареєструватись</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
