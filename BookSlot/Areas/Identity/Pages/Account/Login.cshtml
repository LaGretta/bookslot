@page
@model LoginModel
@{
    ViewData["Title"] = "Вхід";
}

<div class="bs-auth-shell">
    <section class="bs-auth-panel" aria-labelledby="login-title">
        <div class="bs-auth-head">
            <a asp-page="/Index" class="bs-auth-brand" aria-label="BookSlot">
                <span class="bs-auth-mark" aria-hidden="true"><span></span></span>
                <span>BookSlot</span>
            </a>
            <div class="bs-auth-kicker">// безпечний вхід</div>
            <h1 id="login-title">Увійти в акаунт</h1>
            <p>Поверніться до записів, розкладу й AI-помічника без зайвого шуму.</p>
        </div>

        <div class="bs-auth-card">
            <form asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Password" class="form-label fw-semibold">Пароль</label>
                    <input asp-for="Input.Password" class="form-control" placeholder="ваш пароль" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary bs-auth-submit w-100">Увійти</button>

                <div class="text-center mt-3">
                    <a asp-page="./ForgotPassword" class="bs-auth-link">Забули пароль?</a>
                </div>
            </form>
        </div>

        <p class="bs-auth-switch">
            Немає акаунту? <a asp-page="./Register">Зареєструватись</a>
        </p>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
